# PostgreSQL (Railway auto-provides DATABASE_URL)
DATABASE_URL=postgresql://user:password@host:5432/dbname

# Session secret - change this to something random and long
SESSION_SECRET=icc_dispatch_secret_change_me_2024

# Email settings (for dispatch notifications)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
ADMIN_EMAIL=admin@icc.co.za

# App settings
PORT=3000
NODE_ENV=production
