# ── Database ─────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://user:password@localhost:5432/icc_dispatch

# ── App ──────────────────────────────────────────────────────────────────────
SESSION_SECRET=change_this_to_a_very_long_random_string
ADMIN_PASSWORD=icc2024
NODE_ENV=production
PORT=3000

# ── Email (Gmail App Password) ────────────────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=yourmail@gmail.com
SMTP_PASS=your_gmail_app_password
ADMIN_EMAIL=admin@icc.co.za

# ── SMS — BulkSMS South Africa (https://www.bulksms.com) ─────────────────────
BULKSMS_USERNAME=your_bulksms_username
BULKSMS_PASSWORD=your_bulksms_password
BULKSMS_SENDER=ICCDispatch

# ── WhatsApp — Twilio (https://www.twilio.com) ────────────────────────────────
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886

# ── Sage Evolution (optional — local server only) ─────────────────────────────
SAGE_HOST=192.168.1.100
SAGE_DB=SageEvolution
SAGE_USER=sa
SAGE_PASSWORD=your_sage_password
