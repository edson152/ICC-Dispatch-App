# Database (Railway sets this automatically; for local use your PostgreSQL URL)
DATABASE_URL=postgresql://user:password@localhost:5432/icc_dispatch

# Session
SESSION_SECRET=change_this_to_a_long_random_string_for_production

# Admin login password (default: icc2024)
ADMIN_PASSWORD=icc2024

# Email notifications (Gmail App Password)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=yourmail@gmail.com
SMTP_PASS=your_gmail_app_password
ADMIN_EMAIL=admin@icc.co.za

# SMS — BulkSMS South Africa (https://www.bulksms.com)
BULKSMS_USERNAME=your_bulksms_username
BULKSMS_PASSWORD=your_bulksms_password
BULKSMS_SENDER=ICCDispatch

NODE_ENV=production
