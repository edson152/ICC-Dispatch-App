<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8"><meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= truck.truck_name %> — Deliveries</title>
  <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@400;600;700;800&display=swap" rel="stylesheet">
  <style>
    *{margin:0;padding:0;box-sizing:border-box;}
    body{font-family:'Poppins',sans-serif;background:#F4F6FA;min-height:100vh;}
    .header{background:#0D2B5E;padding:20px 16px;color:white;}
    .header h1{font-size:17px;font-weight:800;margin:0 0 2px;}
    .header p{font-size:12px;color:rgba(255,255,255,0.65);}
    .progress-bar{background:#1A4A9C;padding:12px 16px;display:flex;gap:12px;align-items:center;}
    .prog-text{font-size:13px;color:white;font-weight:600;}
    .prog-track{flex:1;background:rgba(255,255,255,0.2);border-radius:10px;height:8px;}
    .prog-fill{background:#63B3ED;height:100%;border-radius:10px;transition:width 0.5s;}
    .stops{padding:12px;}
    .stop-card{background:white;border-radius:12px;padding:16px;margin-bottom:10px;border:2px solid #E2E8F0;box-shadow:0 2px 6px rgba(0,0,0,0.04);}
    .stop-card.done{opacity:0.55;border-color:#38A169;}
    .stop-num{font-size:11px;font-weight:700;color:#718096;text-transform:uppercase;letter-spacing:0.5px;margin-bottom:6px;}
    .stop-cust{font-size:15px;font-weight:700;color:#0D2B5E;margin-bottom:4px;}
    .stop-addr{font-size:12px;color:#718096;margin-bottom:8px;}
    .stop-pkgs{font-size:12px;color:#1A4A9C;font-weight:600;margin-bottom:10px;}
    .btn-row{display:flex;gap:8px;}
    .btn{display:inline-flex;align-items:center;justify-content:center;gap:6px;padding:10px 14px;border-radius:8px;font-family:'Poppins',sans-serif;font-size:12px;font-weight:700;border:none;cursor:pointer;text-decoration:none;flex:1;}
    .btn-green{background:#38A169;color:white;}
    .btn-blue{background:#1A4A9C;color:white;}
    .btn-maps{background:#4A90D9;color:white;}
    .btn-call{background:#38A169;color:white;}
    .done-badge{background:rgba(56,161,105,0.12);color:#38A169;padding:4px 10px;border-radius:20px;font-size:11px;font-weight:700;display:inline-block;}
    .empty{text-align:center;padding:60px 20px;color:#718096;}
    .empty-icon{font-size:56px;margin-bottom:12px;}
  </style>
</head>
<body>
<div class="header">
  <h1>🚛 <%= truck.truck_name %></h1>
  <p><%= truck.license_plate %> · <%= truck.driver_name||'' %> <%= truck.driver_surname||'' %></p>
</div>

<% const total = stops.length; const done = stops.filter(s=>s.stop_status==='delivered').length; const pct = total>0?Math.round(done/total*100):0; %>
<div class="progress-bar">
  <span class="prog-text"><%= done %>/<%= total %> delivered</span>
  <div class="prog-track"><div class="prog-fill" style="width:<%= pct %>%"></div></div>
  <span class="prog-text"><%= pct %>%</span>
</div>

<div class="stops">
  <% if (!stops.length) { %>
    <div class="empty"><div class="empty-icon">🎉</div><p>No active deliveries assigned.<br>Check with the office.</p></div>
  <% } %>

  <% stops.forEach((s, i) => { %>
    <div class="stop-card <%= s.stop_status==='delivered'?'done':'' %>" id="stop-<%= s.inv_number %>">
      <div class="stop-num">Stop <%= i+1 %> · Invoice #<%= s.inv_number %></div>
      <div class="stop-cust"><%= s.acc_name %></div>
      <div class="stop-addr">📍 <%= (s.address||'')+(s.city?', '+s.city:'') || 'Address not on file' %></div>
      <div class="stop-pkgs">📦 <%= s.total_packages||`${s.bales||0} bales, ${s.boxes||0} boxes` %></div>

      <% if (s.stop_status==='delivered') { %>
        <span class="done-badge">✅ Delivered</span>
      <% } else { %>
        <div class="btn-row">
          <% if (s.address) { %>
            <a href="https://www.google.com/maps/dir/?api=1&destination=<%= encodeURIComponent((s.address||'')+(s.city?', '+s.city:'')+', South Africa') %>" target="_blank" class="btn btn-maps">🗺 Navigate</a>
          <% } %>
          <% if (s.phone) { %>
            <a href="tel:<%= s.phone %>" class="btn btn-call">📞 Call</a>
          <% } %>
          <button class="btn btn-green" onclick="markDelivered(<%= s.inv_number %>, this)">✅ Mark Delivered</button>
        </div>
      <% } %>
    </div>
  <% }) %>
</div>

<script>
async function markDelivered(invNum, btn) {
  if (!confirm('Mark Invoice #' + invNum + ' as delivered?')) return;
  btn.disabled = true;
  btn.textContent = 'Saving...';
  try {
    const r = await fetch('/driver/complete/' + invNum, { method: 'POST' });
    const data = await r.json();
    if (data.ok) {
      const card = document.getElementById('stop-' + invNum);
      card.classList.add('done');
      card.querySelector('.btn-row').innerHTML = '<span class="done-badge">✅ Delivered</span>';
      // Update progress
      setTimeout(() => location.reload(), 1000);
    }
  } catch(e) { alert('Error. Please try again.'); btn.disabled = false; }
}
</script>
</body></html>
