<%- include('partials/head') %>

<div id="loginPage">
  <!-- Left Panel -->
  <div class="login-left">
    <div class="login-left-content">
      <div class="login-brand">
        <img src="/images/logo.png" alt="ICC Logo" class="login-logo-img">
        <div class="login-brand-text">
          <h1>ICC Dispatch</h1>
          <p>Management System</p>
        </div>
      </div>

      <div class="login-illustration">
        <svg viewBox="0 0 420 280" xmlns="http://www.w3.org/2000/svg" class="truck-svg">
          <!-- Road -->
          <rect x="0" y="230" width="420" height="50" fill="rgba(255,255,255,0.08)" rx="4"/>
          <rect x="0" y="248" width="420" height="4" fill="rgba(255,255,255,0.15)" rx="2"/>
          <!-- Road dashes -->
          <rect x="20" y="248" width="40" height="4" fill="rgba(255,255,255,0.35)" rx="2"/>
          <rect x="100" y="248" width="40" height="4" fill="rgba(255,255,255,0.35)" rx="2"/>
          <rect x="180" y="248" width="40" height="4" fill="rgba(255,255,255,0.35)" rx="2"/>
          <rect x="260" y="248" width="40" height="4" fill="rgba(255,255,255,0.35)" rx="2"/>
          <rect x="340" y="248" width="40" height="4" fill="rgba(255,255,255,0.35)" rx="2"/>

          <!-- Truck Body -->
          <rect x="30" y="155" width="220" height="75" fill="rgba(255,255,255,0.18)" rx="6"/>
          <!-- Truck Cab -->
          <rect x="250" y="175" width="110" height="55" fill="rgba(255,255,255,0.22)" rx="8"/>
          <!-- Cab window -->
          <rect x="263" y="185" width="55" height="32" fill="rgba(99,179,237,0.45)" rx="5"/>
          <!-- Cab front slope -->
          <polygon points="320,175 360,195 360,230 320,230" fill="rgba(255,255,255,0.2)"/>
          <!-- Front window -->
          <polygon points="324,180 355,200 355,210 324,210" fill="rgba(99,179,237,0.4)"/>

          <!-- ICC Logo on truck side -->
          <rect x="50" y="170" width="170" height="45" fill="rgba(255,255,255,0.06)" rx="4"/>
          <text x="135" y="200" text-anchor="middle" fill="rgba(255,255,255,0.6)" font-family="Poppins,sans-serif" font-size="14" font-weight="700" letter-spacing="3">ICC</text>

          <!-- Wheels -->
          <circle cx="90" cy="233" r="20" fill="rgba(13,43,94,0.7)" stroke="rgba(255,255,255,0.3)" stroke-width="3"/>
          <circle cx="90" cy="233" r="9" fill="rgba(255,255,255,0.2)"/>
          <circle cx="195" cy="233" r="20" fill="rgba(13,43,94,0.7)" stroke="rgba(255,255,255,0.3)" stroke-width="3"/>
          <circle cx="195" cy="233" r="9" fill="rgba(255,255,255,0.2)"/>
          <circle cx="330" cy="233" r="20" fill="rgba(13,43,94,0.7)" stroke="rgba(255,255,255,0.3)" stroke-width="3"/>
          <circle cx="330" cy="233" r="9" fill="rgba(255,255,255,0.2)"/>

          <!-- Headlight -->
          <rect x="358" y="210" width="10" height="8" fill="rgba(255,240,120,0.85)" rx="2"/>
          <!-- Grill -->
          <rect x="358" y="220" width="10" height="3" fill="rgba(255,255,255,0.3)" rx="1"/>
          <rect x="358" y="225" width="10" height="3" fill="rgba(255,255,255,0.3)" rx="1"/>

          <!-- Packages in truck -->
          <rect x="45" y="168" width="30" height="30" fill="rgba(255,255,255,0.12)" rx="3" stroke="rgba(255,255,255,0.2)" stroke-width="1"/>
          <rect x="85" y="168" width="30" height="30" fill="rgba(255,255,255,0.12)" rx="3" stroke="rgba(255,255,255,0.2)" stroke-width="1"/>
          <rect x="125" y="168" width="30" height="30" fill="rgba(255,255,255,0.12)" rx="3" stroke="rgba(255,255,255,0.2)" stroke-width="1"/>

          <!-- Speed lines -->
          <line x1="0" y1="190" x2="20" y2="190" stroke="rgba(255,255,255,0.2)" stroke-width="2" stroke-linecap="round"/>
          <line x1="0" y1="200" x2="15" y2="200" stroke="rgba(255,255,255,0.15)" stroke-width="1.5" stroke-linecap="round"/>
          <line x1="0" y1="210" x2="10" y2="210" stroke="rgba(255,255,255,0.1)" stroke-width="1" stroke-linecap="round"/>

          <!-- Tracking dots -->
          <circle cx="200" cy="100" r="5" fill="rgba(99,179,237,0.8)"/>
          <circle cx="240" cy="80" r="4" fill="rgba(99,179,237,0.5)"/>
          <circle cx="280" cy="60" r="3" fill="rgba(99,179,237,0.3)"/>
          <line x1="200" y1="100" x2="240" y2="80" stroke="rgba(99,179,237,0.4)" stroke-width="1.5" stroke-dasharray="4,3"/>
          <line x1="240" y1="80" x2="280" y2="60" stroke="rgba(99,179,237,0.3)" stroke-width="1.5" stroke-dasharray="4,3"/>

          <!-- Pin marker -->
          <circle cx="200" cy="85" r="14" fill="rgba(99,179,237,0.25)" stroke="rgba(99,179,237,0.6)" stroke-width="1.5"/>
          <circle cx="200" cy="85" r="5" fill="rgba(99,179,237,0.9)"/>
          <line x1="200" y1="90" x2="200" y2="100" stroke="rgba(99,179,237,0.7)" stroke-width="2"/>
        </svg>
      </div>

      <div class="login-tagline">
        <h2>Track. Dispatch. Deliver.</h2>
        <p>Seamlessly manage your dispatch workflow, transport details, and delivery tracking — all in one place.</p>
      </div>
    </div>
  </div>

  <!-- Right Panel -->
  <div class="login-right">
    <div class="login-card">
      <div class="login-card-header">
        <h2>Welcome Back</h2>
        <p>Sign in to ICC Dispatch System</p>
      </div>

      <% if (error && error.length > 0) { %>
        <div class="alert alert-error" style="margin-bottom:20px;"><span>⚠</span> <%= error[0] %></div>
      <% } %>

      <!-- Tabs -->
      <div class="login-tabs">
        <button class="login-tab active" id="tabEmployee" onclick="switchTab('employee')">Employee</button>
        <button class="login-tab" id="tabAdmin" onclick="switchTab('admin')">Admin</button>
      </div>

      <!-- Employee Form -->
      <form id="formEmployee" method="POST" action="/login/employee">
        <div class="form-row">
          <label>Select Your Name</label>
          <select name="employee_id" class="form-control" required>
            <option value="">— Choose your name —</option>
          </select>
        </div>
        <div class="form-row">
          <label>4-Digit PIN</label>
          <input type="password" name="pin" class="form-control pin-input" maxlength="4"
            placeholder="••••" pattern="\d{4}" inputmode="numeric" required
            oninput="this.value=this.value.replace(/[^0-9]/g,'')">
        </div>
        <button type="submit" class="btn-login">Sign In</button>
      </form>

      <!-- Admin Form -->
      <form id="formAdmin" method="POST" action="/login/admin" style="display:none;">
        <div class="form-row">
          <label>Username</label>
          <input type="text" name="username" class="form-control" placeholder="Admin username" required autocomplete="username">
        </div>
        <div class="form-row">
          <label>Password</label>
          <input type="password" name="password" class="form-control" placeholder="••••••••" required autocomplete="current-password">
        </div>
        <button type="submit" class="btn-login">Admin Sign In</button>
      </form>

      <div class="login-footer">
        <span>ICC_BI · Dispatch Management System</span>
      </div>
    </div>
  </div>
</div>

<script>
  // Load employees for dropdown
  fetch('/employees-list')
    .then(r => r.json())
    .then(data => {
      const sel = document.querySelector('#formEmployee select[name="employee_id"]');
      data.forEach(e => {
        const opt = document.createElement('option');
        opt.value = e.id;
        opt.textContent = e.full_name + ' (' + e.role + ')';
        sel.appendChild(opt);
      });
    });

  function switchTab(tab) {
    document.getElementById('formEmployee').style.display = tab === 'employee' ? '' : 'none';
    document.getElementById('formAdmin').style.display = tab === 'admin' ? '' : 'none';
    document.getElementById('tabEmployee').classList.toggle('active', tab === 'employee');
    document.getElementById('tabAdmin').classList.toggle('active', tab === 'admin');
  }
</script>
</body>
</html>
