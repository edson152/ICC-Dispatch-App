<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Track Order #<%= dispatch.inv_number %> — ICC</title>
  <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@400;600;700;800&display=swap" rel="stylesheet">
  <style>
    *{margin:0;padding:0;box-sizing:border-box;}
    body{font-family:'Poppins',sans-serif;background:#F4F6FA;min-height:100vh;padding:20px;}
    .container{max-width:560px;margin:0 auto;}
    .header{background:#0D2B5E;border-radius:14px;padding:24px 28px;margin-bottom:16px;color:white;}
    .header h1{font-size:18px;font-weight:800;margin:0 0 4px;}
    .header p{font-size:12px;color:rgba(255,255,255,0.6);margin:0;}
    .card{background:white;border-radius:14px;border:1px solid #E2E8F0;padding:22px 24px;margin-bottom:14px;box-shadow:0 2px 8px rgba(0,0,0,0.04);}
    .status-bar{display:flex;justify-content:space-between;margin-bottom:24px;position:relative;}
    .status-bar::before{content:'';position:absolute;top:16px;left:0;right:0;height:3px;background:#E2E8F0;z-index:0;}
    .step{display:flex;flex-direction:column;align-items:center;gap:8px;flex:1;position:relative;z-index:1;}
    .step-dot{width:32px;height:32px;border-radius:50%;display:flex;align-items:center;justify-content:center;font-size:14px;border:3px solid white;box-shadow:0 0 0 2px #E2E8F0;}
    .step-dot.done{background:#38A169;box-shadow:0 0 0 2px #38A169;}
    .step-dot.active{background:#1A4A9C;box-shadow:0 0 0 2px #1A4A9C;animation:pulse 2s infinite;}
    .step-dot.pending{background:#E2E8F0;}
    .step-label{font-size:10px;font-weight:600;color:#718096;text-align:center;text-transform:uppercase;letter-spacing:0.5px;}
    @keyframes pulse{0%,100%{transform:scale(1);}50%{transform:scale(1.1);}}
    .field{display:flex;justify-content:space-between;padding:10px 0;border-bottom:1px solid #F4F6FA;font-size:13px;}
    .field:last-child{border-bottom:none;}
    .field-label{color:#718096;font-weight:500;}
    .field-value{font-weight:600;color:#1A202C;text-align:right;max-width:55%;}
    .badge{display:inline-flex;padding:3px 10px;border-radius:20px;font-size:11px;font-weight:700;}
    .badge-pending{background:rgba(214,158,46,0.12);color:#D69E2E;}
    .badge-dispatched{background:rgba(26,74,156,0.12);color:#1A4A9C;}
    .badge-delivered{background:rgba(56,161,105,0.12);color:#38A169;}
    .maps-btn{display:block;background:#1A4A9C;color:white;text-decoration:none;padding:12px;border-radius:10px;text-align:center;font-weight:700;font-size:14px;margin-top:14px;}
    .call-btn{display:block;background:#38A169;color:white;text-decoration:none;padding:12px;border-radius:10px;text-align:center;font-weight:700;font-size:14px;margin-top:8px;}
    .footer{text-align:center;font-size:11px;color:#A0AEC0;margin-top:20px;}
  </style>
</head>
<body>
<div class="container">
  <div class="header">
    <h1>Industrial Clothing Company</h1>
    <p>Order Tracking — Invoice #<%= dispatch.inv_number %></p>
  </div>

  <div class="card">
    <div class="status-bar">
      <div class="step">
        <div class="step-dot done">📦</div>
        <div class="step-label">Processing</div>
      </div>
      <div class="step">
        <div class="step-dot <%= dispatch.dispatch_status==='dispatched'||dispatch.dispatch_status==='delivered'?'done':'pending' %>">🚚</div>
        <div class="step-label">Dispatched</div>
      </div>
      <div class="step">
        <div class="step-dot <%= dispatch.dispatch_status==='delivered'?'done':dispatch.dispatch_status==='dispatched'?'active':'pending' %>">✅</div>
        <div class="step-label">Delivered</div>
      </div>
    </div>

    <div class="field">
      <span class="field-label">Status</span>
      <span class="field-value">
        <span class="badge badge-<%= dispatch.dispatch_status||'pending' %>">
          <%= dispatch.dispatch_status==='delivered'?'✅ Delivered':dispatch.dispatch_status==='dispatched'?'🚚 On the way':'⏳ Processing' %>
        </span>
      </span>
    </div>
    <div class="field"><span class="field-label">Invoice #</span><span class="field-value">#<%= dispatch.inv_number %></span></div>
    <div class="field"><span class="field-label">Customer</span><span class="field-value"><%= dispatch.acc_name %></span></div>
    <div class="field"><span class="field-label">Packages</span><span class="field-value"><%= dispatch.total_packages||'—' %></span></div>
    <% if (dispatch.delivery_method) { %>
    <div class="field"><span class="field-label">Delivery Method</span><span class="field-value"><%= dispatch.delivery_method %></span></div>
    <% } %>
    <% if (dispatch.transport_company) { %>
    <div class="field"><span class="field-label">Transport</span><span class="field-value"><%= dispatch.transport_company %></span></div>
    <% } %>
    <% if (dispatch.tracking_number) { %>
    <div class="field"><span class="field-label">Tracking #</span><span class="field-value" style="color:#1A4A9C;"><%= dispatch.tracking_number %></span></div>
    <% } %>
    <% if (dispatch.dispatched_at) { %>
    <div class="field"><span class="field-label">Dispatched</span><span class="field-value"><%= new Date(dispatch.dispatched_at).toLocaleString('en-ZA') %></span></div>
    <% } %>
    <% if (dispatch.delivered_at) { %>
    <div class="field"><span class="field-label">Delivered</span><span class="field-value" style="color:#38A169;"><%= new Date(dispatch.delivered_at).toLocaleString('en-ZA') %></span></div>
    <% } %>
  </div>

  <% if (dispatch.dispatch_status==='dispatched' && (dispatch.driver_first_name||dispatch.driver_phone)) { %>
  <div class="card">
    <div style="font-size:12px;font-weight:700;color:#718096;text-transform:uppercase;letter-spacing:0.5px;margin-bottom:14px;">🚗 Driver Details</div>
    <% if (dispatch.driver_first_name) { %>
    <div class="field"><span class="field-label">Driver</span><span class="field-value"><%= dispatch.driver_first_name %> <%= dispatch.driver_surname||'' %></span></div>
    <% } %>
    <% if (dispatch.license_plate) { %>
    <div class="field"><span class="field-label">Vehicle Plate</span><span class="field-value"><%= dispatch.license_plate %></span></div>
    <% } %>
    <% if (dispatch.driver_phone) { %>
    <a href="tel:<%= dispatch.driver_phone %>" class="call-btn">📞 Call Driver — <%= dispatch.driver_phone %></a>
    <% } %>
  </div>
  <% } %>

  <% if (dispatch.receipt_condition) { %>
  <div class="card" style="border-color:#38A169;">
    <div style="font-size:12px;font-weight:700;color:#38A169;text-transform:uppercase;letter-spacing:0.5px;margin-bottom:14px;">✅ Delivery Confirmed</div>
    <div class="field"><span class="field-label">Received By</span><span class="field-value"><%= dispatch.received_by||'—' %></span></div>
    <div class="field"><span class="field-label">Condition</span><span class="field-value"><%= dispatch.receipt_condition %></span></div>
    <div class="field"><span class="field-label">Date</span><span class="field-value"><%= dispatch.receipt_date ? new Date(dispatch.receipt_date).toLocaleString('en-ZA') : '—' %></span></div>
  </div>
  <% } %>

  <div class="footer">Industrial Clothing Company · Dispatch Tracking · Powered by ICC Dispatch System</div>
</div>
</body></html>
