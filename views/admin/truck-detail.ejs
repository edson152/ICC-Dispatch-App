<%- include('../partials/head') %>
<div class="app-layout">
  <%- include('../partials/sidebar') %>
  <div class="main-content">
    <%- include('../partials/topbar') %>
    <div class="page-body">
      <div style="margin-bottom:16px;"><a href="javascript:history.back()" class="btn btn-outline btn-sm">← Back to Fleet</a></div>
      <div class="card" style="margin-bottom:20px;">
        <div class="card-header">
          <span class="card-title">🚛 <%= truck.truck_name %></span>
          <span class="badge <%=truck.is_active?'badge-success':'badge-danger'%>"><%= truck.is_active?'Active':'Inactive' %></span>
        </div>
        <div class="card-body">
          <div class="detail-grid">
            <div class="detail-field highlight"><label>License Plate</label><span><%= truck.license_plate %></span></div>
            <div class="detail-field highlight"><label>Driver Name</label><span><%= truck.driver_name||'—' %> <%= truck.driver_surname||'' %></span></div>
            <div class="detail-field"><label>Driver Phone</label><span><%= truck.driver_phone||'—' %></span></div>
            <div class="detail-field"><label>Driver ID</label><span><%= truck.driver_id_number||'—' %></span></div>
            <div class="detail-field"><label>Added</label><span><%= new Date(truck.created_at).toLocaleDateString('en-ZA') %></span></div>
            <div class="detail-field"><label>Notes</label><span><%= truck.notes||'—' %></span></div>
          </div>
          <div style="display:flex;gap:16px;margin-top:20px;">
            <% if (truck.driver_photo) { %>
              <div style="text-align:center;">
                <img src="/uploads/drivers/<%= truck.driver_photo %>" style="width:120px;height:120px;object-fit:cover;border-radius:10px;border:2px solid var(--mid-grey);">
                <div style="font-size:11px;color:var(--dark-grey);margin-top:4px;">Driver Photo</div>
              </div>
            <% } %>
            <% if (truck.driver_license_photo) { %>
              <div style="text-align:center;">
                <img src="/uploads/licenses/<%= truck.driver_license_photo %>" style="width:180px;height:120px;object-fit:cover;border-radius:10px;border:2px solid var(--mid-grey);">
                <div style="font-size:11px;color:var(--dark-grey);margin-top:4px;">License Photo</div>
              </div>
            <% } %>
          </div>
        </div>
      </div>
      <div class="card">
        <div class="card-header"><span class="card-title">📦 Dispatch History (<%= dispatches.length %>)</span></div>
        <div class="table-wrapper">
          <table>
            <thead><tr><th>Invoice #</th><th>Date</th><th>Customer</th><th>Packages</th><th>Status</th><th>Captured By</th></tr></thead>
            <tbody>
              <% dispatches.forEach(d => { %>
                <tr>
                  <td><strong style="color:var(--deep-blue)">#<%= d.inv_number %></strong></td>
                  <td><%= d.inv_date ? new Date(d.inv_date).toLocaleDateString('en-ZA',{day:'2-digit',month:'short',year:'numeric'}) : '—' %></td>
                  <td class="truncate" style="max-width:160px;"><%= d.acc_name %></td>
                  <td class="small"><%= d.total_packages||'—' %></td>
                  <td><span class="badge <%=d.dispatch_status==='delivered'?'badge-success':d.dispatch_status==='dispatched'?'badge-info':'badge-warning'%>"><%= d.dispatch_status %></span></td>
                  <td><%= d.captured_by||'—' %></td>
                </tr>
              <% }) %>
            </tbody>
          </table>
        </div>
      </div>
    </div>
  </div>
</div>
<script src="/js/app.js"></script>
</body></html>
