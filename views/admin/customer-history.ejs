<%- include('../partials/head') %>
<div class="app-layout">
  <%- include('../partials/sidebar') %>
  <div class="main-content">
    <%- include('../partials/topbar') %>
    <div class="page-body">
      <div style="margin-bottom:16px;"><a href="javascript:history.back()" class="btn btn-outline btn-sm">← Back</a></div>
      <div class="card" style="margin-bottom:20px;">
        <div class="card-header"><span class="card-title">🏢 <%= customer.acc_name %></span></div>
        <div class="card-body">
          <div class="detail-grid">
            <div class="detail-field highlight"><label>Account No</label><span><%= customer.acc_no %></span></div>
            <div class="detail-field"><label>Email</label><span><%= customer.email||'—' %></span></div>
            <div class="detail-field"><label>Phone</label><span><%= customer.phone||'—' %></span></div>
            <div class="detail-field" style="grid-column:span 2;"><label>Address</label><span><%= customer.address ? customer.address+(customer.city?', '+customer.city:'') : '—' %></span></div>
            <div class="detail-field"><label>Total Orders</label><span style="font-weight:700;color:var(--medium-blue);"><%= dispatches.length %></span></div>
            <div class="detail-field"><label>Receipts Captured</label><span style="font-weight:700;color:var(--success);"><%= receipts.length %></span></div>
            <div class="detail-field"><label>Returns/Issues</label><span style="font-weight:700;color:var(--danger);"><%= returns.length %></span></div>
          </div>
        </div>
      </div>
      <div class="card" style="margin-bottom:20px;">
        <div class="card-header"><span class="card-title">📦 Order History (<%= dispatches.length %>)</span></div>
        <div class="table-wrapper">
          <table>
            <thead><tr><th>Invoice #</th><th>Date</th><th>Packages</th><th>Value</th><th>Transport</th><th>Status</th></tr></thead>
            <tbody>
              <% dispatches.forEach(d => { %>
                <tr>
                  <td><strong style="color:var(--deep-blue)">#<%= d.inv_number %></strong></td>
                  <td><%= d.inv_date ? new Date(d.inv_date).toLocaleDateString('en-ZA',{day:'2-digit',month:'short',year:'numeric'}) : '—' %></td>
                  <td class="small"><%= d.total_packages||'—' %></td>
                  <td>R <%= parseFloat(d.inv_tot_excl||0).toLocaleString('en-ZA',{minimumFractionDigits:2}) %></td>
                  <td class="small"><%= d.transport_company||d.truck_name||'—' %></td>
                  <td><span class="badge <%=d.dispatch_status==='delivered'?'badge-success':d.dispatch_status==='dispatched'?'badge-info':'badge-warning'%>"><%= d.dispatch_status||'pending' %></span></td>
                </tr>
              <% }) %>
            </tbody>
          </table>
        </div>
      </div>
      <% if (returns.length) { %>
      <div class="card">
        <div class="card-header"><span class="card-title" style="color:var(--danger);">⚠ Returns & Issues (<%= returns.length %>)</span></div>
        <div class="table-wrapper">
          <table>
            <thead><tr><th>Invoice #</th><th>Type</th><th>Description</th><th>Reported By</th><th>Date</th><th>Resolved</th></tr></thead>
            <tbody>
              <% returns.forEach(r => { %>
                <tr>
                  <td><strong>#<%= r.inv_number %></strong></td>
                  <td><span class="badge badge-danger"><%= r.return_type %></span></td>
                  <td class="small"><%= r.description||'—' %></td>
                  <td><%= r.reported_by||'—' %></td>
                  <td class="small"><%= new Date(r.created_at).toLocaleDateString('en-ZA') %></td>
                  <td><span class="badge <%=r.resolved?'badge-success':'badge-warning'%>"><%= r.resolved?'✅ Yes':'⏳ Open' %></span></td>
                </tr>
              <% }) %>
            </tbody>
          </table>
        </div>
      </div>
      <% } %>
    </div>
  </div>
</div>
<script src="/js/app.js"></script>
</body></html>
