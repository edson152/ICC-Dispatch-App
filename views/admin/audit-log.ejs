<%- include('../partials/head') %>
<div class="app-layout">
  <%- include('../partials/sidebar') %>
  <div class="main-content">
    <%- include('../partials/topbar') %>
    <div class="page-body">
      <div style="margin-bottom:16px;"><a href="javascript:history.back()" class="btn btn-outline btn-sm">← Back</a></div>

      <div class="card">
        <div class="card-header">
          <span class="card-title">🔍 System Audit Log</span>
          <span style="font-size:12px;color:var(--dark-grey);"><%= logs.length %> entries</span>
        </div>
        <div class="table-wrapper" style="overflow-x:auto;">
          <table>
            <thead>
              <tr>
                <th>#</th><th>User</th><th>Role</th><th>Action</th><th>Detail</th><th>Date &amp; Time</th>
              </tr>
            </thead>
            <tbody>
              <% logs.forEach(l => { %>
                <tr>
                  <td><%= l.id %></td>
                  <td><strong style="color:var(--medium-blue)"><%= l.user_name||'—' %></strong></td>
                  <td><span class="badge <%=l.user_role==='admin'?'badge-danger':l.user_role==='driver'?'badge-warning':'badge-info'%>"><%= l.user_role||'—' %></span></td>
                  <td><span style="font-family:monospace;font-size:12px;background:var(--soft-grey);padding:2px 6px;border-radius:4px;"><%= l.action %></span></td>
                  <td style="font-size:12px;color:var(--dark-grey);max-width:300px;"><%= l.detail||'—' %></td>
                  <td class="small nowrap"><%= new Date(l.created_at).toLocaleString('en-ZA') %></td>
                </tr>
              <% }) %>
              <% if (!logs.length) { %>
                <tr><td colspan="6" style="text-align:center;padding:40px;color:var(--dark-grey);">No audit entries yet.</td></tr>
              <% } %>
            </tbody>
          </table>
        </div>
      </div>

    </div>
  </div>
</div>
<script src="/js/app.js"></script>
</body></html>
