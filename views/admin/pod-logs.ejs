<%- include('../partials/head') %>
<div class="app-layout">
  <%- include('../partials/sidebar') %>
  <div class="main-content">
    <%- include('../partials/topbar') %>
    <div class="page-body">
      <div style="margin-bottom:16px;display:flex;gap:10px;align-items:center;flex-wrap:wrap;">
        <a href="javascript:history.back()" class="btn btn-outline btn-sm">← Back</a>
        <a href="/pod/pending" class="btn btn-outline btn-sm">📋 Pending PODs</a>
      </div>

      <!-- Search -->
      <form method="GET" action="/pod/logs" class="filter-bar" style="margin-bottom:16px;">
        <div class="search-wrap">
          <input class="search-input" type="text" name="search" value="<%= search %>" placeholder="Search invoice, customer...">
        </div>
        <button type="submit" class="btn btn-blue btn-sm">Search</button>
        <a href="/pod/logs" class="btn btn-outline btn-sm">Clear</a>
        <span style="font-size:12px;color:var(--dark-grey);margin-left:8px;"><%= total %> completed orders</span>
      </form>

      <div class="card">
        <div class="card-header">
          <span class="card-title" style="color:var(--success);">📁 POD Archive — Completed Orders</span>
          <span style="font-size:12px;color:var(--dark-grey);">Permanent record · Nothing is deleted from here</span>
        </div>
        <div class="table-wrapper" style="overflow-x:auto;">
          <table style="min-width:1000px;">
            <thead>
              <tr>
                <th>Invoice #</th>
                <th>Customer</th>
                <th>Acc No</th>
                <th>Date</th>
                <th>Packages</th>
                <th>Delivery</th>
                <th>Transport</th>
                <th>Driver</th>
                <th>Plate</th>
                <th>Received By</th>
                <th>Condition</th>
                <th>Captured By</th>
                <th>Archived</th>
                <th>POD</th>
              </tr>
            </thead>
            <tbody>
              <% logs.forEach(l => { %>
                <tr style="background:rgba(56,161,105,0.03);">
                  <td><strong style="color:var(--success)">#<%= l.inv_number %></strong></td>
                  <td class="truncate" style="max-width:140px;" title="<%= l.acc_name %>"><%= l.acc_name %></td>
                  <td class="small text-muted"><%= l.acc_no||'—' %></td>
                  <td class="nowrap"><%= l.inv_date?new Date(l.inv_date).toLocaleDateString('en-ZA',{day:'2-digit',month:'short',year:'numeric'}):'—' %></td>
                  <td class="small"><%= l.total_packages||'—' %></td>
                  <td><span class="badge badge-info"><%= l.delivery_method||'—' %></span></td>
                  <td class="small"><%= l.transport_company||'—' %></td>
                  <td class="small"><%= l.driver_name||'—' %></td>
                  <td class="small"><%= l.license_plate||'—' %></td>
                  <td class="small"><%= l.received_by||'—' %></td>
                  <td>
                    <% if (l.receipt_condition) { %>
                      <span class="badge <%=l.receipt_condition==='Good'?'badge-success':l.receipt_condition==='Damaged'?'badge-danger':'badge-warning'%>"><%= l.receipt_condition %></span>
                    <% } else { %>—<% } %>
                  </td>
                  <td><strong><%= l.captured_by||'—' %></strong></td>
                  <td class="small nowrap"><%= l.archived_at?new Date(l.archived_at).toLocaleDateString('en-ZA',{day:'2-digit',month:'short',year:'numeric'}):'—' %></td>
                  <td>
                    <% if (l.pod_scan_path) { %>
                      <a href="/uploads/pods/<%= l.pod_scan_path %>" target="_blank" class="btn btn-outline btn-sm">👁 View</a>
                    <% } else { %>
                      <span class="text-muted small">—</span>
                    <% } %>
                  </td>
                </tr>
              <% }) %>
              <% if (!logs.length) { %>
                <tr><td colspan="14" style="text-align:center;padding:40px;color:var(--dark-grey);">No completed orders yet. Scan PODs to populate this archive.</td></tr>
              <% } %>
            </tbody>
          </table>
        </div>

        <!-- Pagination -->
        <% if (totalPages > 1) { %>
          <div style="display:flex;justify-content:center;gap:8px;padding:16px;">
            <% for(let p=1;p<=totalPages;p++) { %>
              <a href="/pod/logs?page=<%= p %>&search=<%= search %>" class="btn btn-sm <%=p===page?'btn-blue':'btn-outline'%>"><%= p %></a>
            <% } %>
          </div>
        <% } %>
      </div>

    </div>
  </div>
</div>
<script src="/js/app.js"></script>
</body></html>
