<%- include('../partials/head') %>
<div class="app-layout"><%- include('../partials/sidebar') %><div class="main-content"><%- include('../partials/topbar') %>
<div class="page-body">
  <div style="margin-bottom:16px;"><a href="javascript:history.back()" class="btn btn-outline btn-sm">← Back</a></div>
  <div class="stat-grid" style="margin-bottom:20px;">
    <div class="stat-card" style="border:2px solid var(--danger);"><div class="stat-icon orange">⚠</div><div><div class="stat-label">Orders Out for Delivery</div><div class="stat-value"><%= atRisk.cnt %></div></div></div>
    <div class="stat-card" style="border:2px solid var(--danger);"><div class="stat-icon orange">💰</div><div><div class="stat-label">Value Currently at Risk</div><div class="stat-value" style="font-size:15px;color:var(--danger);">R <%= parseFloat(atRisk.total_value||0).toLocaleString('en-ZA',{minimumFractionDigits:2}) %></div></div></div>
    <div class="stat-card"><div class="stat-icon blue">⚖</div><div><div class="stat-label">Total Weight Out</div><div class="stat-value"><%= parseFloat(atRisk.total_weight||0).toFixed(1) %> kg</div></div></div>
  </div>
  <div style="display:grid;grid-template-columns:1fr 1fr;gap:20px;margin-bottom:20px;">
    <div class="card"><div class="card-header"><span class="card-title">By Delivery Method</span></div><div class="card-body">
      <% byMethod.forEach(r => { %>
        <div style="display:flex;justify-content:space-between;padding:8px 0;border-bottom:1px solid var(--mid-grey);font-size:13px;">
          <span class="badge badge-info"><%= r.delivery_method %></span>
          <span><%= r.cnt %> orders · <strong style="color:var(--danger);">R <%= parseFloat(r.total_value).toLocaleString('en-ZA',{minimumFractionDigits:2}) %></strong></span>
        </div>
      <% }) %>
    </div></div>
    <div class="card"><div class="card-header"><span class="card-title">ℹ About This Report</span></div><div class="card-body">
      <p style="font-size:13px;color:var(--dark-grey);line-height:1.8;">Shows all orders currently <strong>dispatched but not yet confirmed delivered</strong>. These represent goods in transit. Useful for insurance, management oversight, and following up on delayed deliveries.</p>
    </div></div>
  </div>
  <div class="card"><div class="card-header"><span class="card-title">⚠ Orders Currently Out (<%= dispatches.length %>)</span></div>
    <div class="table-wrapper"><table>
      <thead><tr><th>Invoice #</th><th>Customer</th><th>Value</th><th>Packages</th><th>Delivery</th><th>Transport</th><th>Driver Phone</th><th>Dispatched</th></tr></thead>
      <tbody>
        <% dispatches.forEach(d => { %>
          <tr>
            <td><strong style="color:var(--danger)">#<%= d.inv_number %></strong></td>
            <td class="truncate" style="max-width:140px;"><%= d.acc_name %></td>
            <td style="font-weight:700;color:var(--danger);">R <%= parseFloat(d.inv_tot_excl||0).toLocaleString('en-ZA',{minimumFractionDigits:2}) %></td>
            <td class="small"><%= d.total_packages||'—' %></td>
            <td><span class="badge badge-info"><%= d.delivery_method %></span></td>
            <td class="small"><%= d.transport_company||d.truck_name||'—' %></td>
            <td class="small"><%= d.driver_phone||'—' %></td>
            <td class="small nowrap"><%= d.dispatched_at?new Date(d.dispatched_at).toLocaleString('en-ZA'):'—' %></td>
          </tr>
        <% }) %>
      </tbody>
    </table></div>
  </div>
</div></div></div>
<script src="/js/app.js"></script></body></html>
