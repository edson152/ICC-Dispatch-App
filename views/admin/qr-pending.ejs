<%- include('../partials/head') %>
<div class="app-layout">
  <%- include('../partials/sidebar') %>
  <div class="main-content">
    <%- include('../partials/topbar') %>
    <div class="page-body">
      <div style="margin-bottom:16px;display:flex;gap:10px;align-items:center;">
        <a href="javascript:history.back()" class="btn btn-outline btn-sm">← Back</a>
      </div>

      <div class="card">
        <div class="card-header">
          <span class="card-title">📋 Pending PODs — Awaiting Confirmation <span class="badge badge-warning"><%= pending.length %></span></span>
          <a href="/pod/logs" class="btn btn-outline btn-sm">📁 View Completed Archive</a>
        </div>

        <% if (!pending.length) { %>
          <div class="empty-state">
            <div class="empty-state-icon">🎉</div>
            <h3>All PODs accounted for!</h3>
            <p>No pending confirmations — everything has been processed.</p>
          </div>
        <% } else { %>
        <div class="table-wrapper">
          <table>
            <thead>
              <tr>
                <th>Invoice #</th>
                <th>Customer</th>
                <th>Date</th>
                <th>Packages</th>
                <th>Delivery</th>
                <th>Transport</th>
                <th>QR Label</th>
                <th>Printed</th>
                <th>Confirm POD Received</th>
              </tr>
            </thead>
            <tbody>
              <% pending.forEach(p => { %>
                <tr id="row-<%= p.inv_number %>">
                  <td><strong style="color:var(--deep-blue)">#<%= p.inv_number %></strong></td>
                  <td class="truncate" style="max-width:150px;" title="<%= p.acc_name %>"><%= p.acc_name %></td>
                  <td class="nowrap"><%= p.inv_date?new Date(p.inv_date).toLocaleDateString('en-ZA',{day:'2-digit',month:'short',year:'numeric'}):'—' %></td>
                  <td class="small"><%= p.total_packages||'—' %></td>
                  <td><span class="badge badge-info"><%= p.delivery_method||'—' %></span></td>
                  <td class="small"><%= p.transport_company||'—' %></td>
                  <td>
                    <a href="/pod/label/<%= p.inv_number %>" target="_blank" class="btn btn-blue btn-sm">🖨 Print Label</a>
                  </td>
                  <td>
                    <span class="badge <%=p.printed?'badge-success':'badge-warning'%>">
                      <%= p.printed?'✔ Yes':'Not yet' %>
                    </span>
                  </td>
                  <td>
                    <button class="btn btn-success btn-sm" onclick="confirmPOD(<%= p.inv_number %>, '<%= p.acc_name.replace(/'/g, "\\'") %>')">
                      ✅ POD Received
                    </button>
                  </td>
                </tr>
              <% }) %>
            </tbody>
          </table>
        </div>
        <% } %>

        <div style="margin:16px 20px 20px;background:rgba(74,144,217,0.07);border:1px solid rgba(74,144,217,0.2);border-radius:10px;padding:16px 20px;font-size:13px;color:var(--medium-blue);">
          <strong>How it works:</strong><br>
          1. Click <strong>🖨 Print Label</strong> on any dispatch — a label with a QR code prints out<br>
          2. Attach the printed label to the goods before they go out with the driver<br>
          3. When the signed POD document comes back to the office, click <strong>✅ POD Received</strong> to confirm it<br>
          4. The order is marked as delivered and moves to the <a href="/pod/logs" style="color:var(--deep-blue);font-weight:700;">completed archive →</a>
        </div>
      </div>

    </div>
  </div>
</div>

<script>
function confirmPOD(invNum, custName) {
  iccConfirm(
    `Confirm POD received for Invoice #${invNum} — ${custName}?`,
    async () => {
      try {
        const r = await fetch(`/pod/scan-manual/${invNum}`, { method: 'POST' });
        const data = await r.json();
        if (data.ok) {
          const row = document.getElementById('row-' + invNum);
          if (row) {
            row.style.transition = 'opacity 0.5s, transform 0.5s';
            row.style.opacity = '0';
            row.style.transform = 'translateX(20px)';
            setTimeout(() => row.remove(), 500);
          }
          showToast(`Invoice #${invNum} confirmed and archived ✅`, 'success');
        } else {
          showToast(data.error || 'Error confirming POD', 'error');
        }
      } catch(e) {
        showToast('Error. Please try again.', 'error');
      }
    },
    'Confirm POD Received',
    '📋'
  );
}
</script>
<script src="/js/app.js"></script>
</body></html>
