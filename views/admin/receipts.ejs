<%- include('../partials/head') %>
<div class="app-layout">
  <%- include('../partials/sidebar') %>
  <div class="main-content">
    <%- include('../partials/topbar') %>
    <div class="page-body">

      <div class="card">
        <div class="card-header">
          <span class="card-title">🧾 All Delivery Receipts</span>
          <span style="font-size:12px;color:var(--dark-grey);"><%= receipts.length %> total</span>
        </div>
        <div class="table-wrapper" style="overflow-x:auto;">
          <table style="min-width:1100px;">
            <thead>
              <tr>
                <th>Receipt #</th><th>Invoice #</th><th>Customer</th><th>Email</th>
                <th>Receipt Date</th><th>Received By</th><th>Condition</th>
                <th>Transport Co.</th><th>Tracking #</th><th>Notes</th>
                <th>Captured By</th><th>Captured At</th>
              </tr>
            </thead>
            <tbody>
              <% receipts.forEach(r => { %>
                <tr>
                  <td><strong style="color:var(--deep-blue)">#<%= r.id %></strong></td>
                  <td><a href="/receipts/view/<%= r.id %>" style="color:var(--medium-blue);font-weight:600;">#<%= r.inv_number %></a></td>
                  <td class="truncate" style="max-width:150px;" title="<%= r.acc_name %>"><%= r.acc_name %></td>
                  <td class="small text-muted"><%= r.customer_email || '—' %></td>
                  <td class="nowrap"><%= r.receipt_date ? new Date(r.receipt_date).toLocaleDateString('en-ZA',{day:'2-digit',month:'short',year:'numeric'}) : '—' %></td>
                  <td><%= r.received_by || '—' %></td>
                  <td><span class="badge <%= r.condition === 'Good' ? 'badge-success' : r.condition === 'Damaged' ? 'badge-danger' : 'badge-warning' %>"><%= r.condition %></span></td>
                  <td><%= r.transport_company || '—' %></td>
                  <td class="small"><%= r.tracking_number || '—' %></td>
                  <td class="small text-muted"><%= r.notes ? r.notes.substring(0,40)+(r.notes.length>40?'...':'') : '—' %></td>
                  <td><strong style="color:var(--medium-blue)"><%= r.captured_by %></strong></td>
                  <td class="small nowrap"><%= r.captured_at ? new Date(r.captured_at).toLocaleString('en-ZA') : '—' %></td>
                </tr>
              <% }) %>
              <% if (receipts.length === 0) { %>
                <tr><td colspan="12" style="text-align:center;padding:40px;color:var(--dark-grey);">No receipts found.</td></tr>
              <% } %>
            </tbody>
          </table>
        </div>
      </div>

    </div>
  </div>
</div>
<script src="/js/app.js"></script>
</body>
</html>
