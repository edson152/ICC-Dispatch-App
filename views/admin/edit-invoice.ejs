<%- include('../partials/head') %>
<div class="app-layout">
  <%- include('../partials/sidebar') %>
  <div class="main-content">
    <%- include('../partials/topbar') %>
    <div class="page-body">
      <div style="margin-bottom:16px;">
        <a href="/admin/dispatches" class="btn btn-outline btn-sm">← Back to Dispatches</a>
      </div>
      <div class="card">
        <div class="card-header">
          <span class="card-title">⚙️ Admin: Edit Invoice #<%= dispatch.inv_number %></span>
          <span style="font-size:12px;color:var(--dark-grey);">Editing as: <strong style="color:var(--medium-blue);"><%= user.name %></strong></span>
        </div>
        <div class="card-body">
          <% if (error && error.length) { %><div class="alert alert-error"><%= error[0] %></div><% } %>

          <div style="background:#FFF5F5;border:1px solid #FC8181;border-radius:8px;padding:12px 16px;margin-bottom:24px;font-size:13px;color:#742a2a;">
            ⚠️ <strong>Admin Edit:</strong> All changes are permanently logged in the audit trail.
          </div>

          <form method="POST" action="/admin/invoices/edit/<%= dispatch.inv_number %>">
            <div class="section-title">📄 Invoice Details</div>
            <div class="form-grid">
              <div class="form-row"><label>Invoice Date</label><input class="form-control" type="date" name="inv_date" value="<%= dispatch.inv_date ? new Date(dispatch.inv_date).toISOString().slice(0,10) : '' %>"></div>
              <div class="form-row"><label>Order Number</label><input class="form-control" name="order_num" value="<%= dispatch.order_num || '' %>"></div>
              <div class="form-row"><label>Account No</label><input class="form-control" name="acc_no" value="<%= dispatch.acc_no || '' %>"></div>
              <div class="form-row" style="grid-column:span 2;"><label>Customer Name</label><input class="form-control" name="acc_name" value="<%= dispatch.acc_name || '' %>"></div>
              <div class="form-row"><label>Customer Email</label><input class="form-control" type="email" name="email" value="<%= dispatch.email || '' %>"></div>
              <div class="form-row"><label>Customer Order No</label><input class="form-control" name="cust_ord_no" value="<%= dispatch.cust_ord_no || '' %>"></div>
            </div>

            <hr class="section-divider">
            <div class="section-title">👥 Staff</div>
            <div class="form-grid">
              <div class="form-row"><label>Internal Rep</label><input class="form-control" name="internal_rep" value="<%= dispatch.internal_rep || '' %>"></div>
              <div class="form-row"><label>External Rep</label><input class="form-control" name="ext_rep" value="<%= dispatch.ext_rep || '' %>"></div>
              <div class="form-row"><label>Picker</label><input class="form-control" name="picker" value="<%= dispatch.picker || '' %>"></div>
              <div class="form-row"><label>Packer 1</label><input class="form-control" name="packer" value="<%= dispatch.packer || '' %>"></div>
              <div class="form-row"><label>Packer 2</label><input class="form-control" name="packer2" value="<%= dispatch.packer2 || '' %>"></div>
              <div class="form-row"><label>Checker</label><input class="form-control" name="checker" value="<%= dispatch.checker || '' %>"></div>
            </div>

            <hr class="section-divider">
            <div class="section-title">📦 Packaging &amp; Delivery</div>
            <div class="form-grid">
              <div class="form-row"><label>Weight (kg)</label><input class="form-control" type="number" step="0.1" name="weight" value="<%= dispatch.weight || 0 %>"></div>
              <div class="form-row"><label>Boxes</label><input class="form-control" type="number" name="boxes" value="<%= dispatch.boxes || 0 %>"></div>
              <div class="form-row"><label>Bales</label><input class="form-control" type="number" name="bales" value="<%= dispatch.bales || 0 %>"></div>
              <div class="form-row"><label>Grey Bags</label><input class="form-control" type="number" name="grey_bags" value="<%= dispatch.grey_bags || 0 %>"></div>
              <div class="form-row"><label>Delivery Method</label>
                <select class="form-control" name="delivery_method">
                  <% ['ICC Truck','Courier','Collection','Post'].forEach(m => { %><option value="<%= m %>" <%= dispatch.delivery_method===m?'selected':'' %>><%= m %></option><% }) %>
                </select>
              </div>
              <div class="form-row"><label>Invoice Total (Excl)</label><input class="form-control" type="number" step="0.01" name="inv_tot_excl" value="<%= dispatch.inv_tot_excl || 0 %>"></div>
            </div>

            <hr class="section-divider">
            <div class="section-title">🚛 Transport Details</div>
            <div class="form-grid">
              <div class="form-row"><label>Transport Company</label><input class="form-control" name="transport_company" value="<%= dispatch.transport_company || '' %>"></div>
              <div class="form-row"><label>Driver First Name</label><input class="form-control" name="driver_first_name" value="<%= dispatch.driver_first_name || '' %>"></div>
              <div class="form-row"><label>Driver Surname</label><input class="form-control" name="driver_surname" value="<%= dispatch.driver_surname || '' %>"></div>
              <div class="form-row"><label>License Plate</label><input class="form-control" name="license_plate" value="<%= dispatch.license_plate || '' %>" style="text-transform:uppercase;"></div>
              <div class="form-row"><label>Tracking / Waybill</label><input class="form-control" name="tracking_number" value="<%= dispatch.tracking_number || '' %>"></div>
              <div class="form-row" style="grid-column:span 2;"><label>Notes</label><input class="form-control" name="notes" value="<%= dispatch.notes || '' %>"></div>
            </div>

            <div style="display:flex;gap:12px;margin-top:16px;">
              <button type="submit" class="btn btn-blue">💾 Save Changes</button>
              <a href="/admin/dispatches" class="btn btn-outline">Cancel</a>
              <form method="POST" action="/admin/invoices/<%= dispatch.inv_number %>?_method=DELETE" onsubmit="return confirm('⚠️ PERMANENTLY DELETE Invoice #<%= dispatch.inv_number %>? This cannot be undone.');" style="margin-left:auto;">
                <input type="hidden" name="_method" value="DELETE">
                <button type="submit" class="btn" style="background:#e53e3e;color:white;">🗑 Delete Invoice</button>
              </form>
            </div>
          </form>

          <!-- Media Gallery -->
          <% if (media && media.length > 0) { %>
            <hr class="section-divider">
            <div class="section-title">🖼️ Goods Media (<%= media.length %> files)</div>
            <div style="display:grid;grid-template-columns:repeat(auto-fill,minmax(160px,1fr));gap:12px;margin-top:12px;">
              <% media.forEach(m => { %>
                <div style="background:white;border:1px solid #e2e8f0;border-radius:8px;overflow:hidden;text-align:center;">
                  <% if (m.mime_type && m.mime_type.startsWith('image/')) { %>
                    <a href="/uploads/goods/<%= m.file_name %>" target="_blank">
                      <img src="/uploads/goods/<%= m.file_name %>" style="width:100%;height:120px;object-fit:cover;">
                    </a>
                  <% } else if (m.mime_type && m.mime_type.startsWith('video/')) { %>
                    <video style="width:100%;height:120px;object-fit:cover;" controls><source src="/uploads/goods/<%= m.file_name %>" type="<%= m.mime_type %>"></video>
                  <% } else { %>
                    <a href="/uploads/goods/<%= m.file_name %>" target="_blank" style="display:block;padding:30px;font-size:32px;">📄</a>
                  <% } %>
                  <div style="padding:8px;font-size:11px;color:var(--dark-grey);">
                    <div style="font-weight:600;" title="<%= m.original_name %>"><%= m.original_name.length>20?m.original_name.substring(0,18)+'...':m.original_name %></div>
                    <div><%= new Date(m.uploaded_at).toLocaleDateString('en-ZA') %> — <%= m.uploaded_by %></div>
                    <div style="font-size:10px;color:var(--dark-grey);">Type: <%= m.media_type %></div>
                  </div>
                </div>
              <% }) %>
            </div>
          <% } %>

          <!-- Edit Log -->
          <% if (editLog && editLog.length > 0) { %>
            <hr class="section-divider">
            <div class="section-title">📋 Edit History</div>
            <div style="background:var(--soft-grey);border-radius:8px;padding:12px;font-size:12px;">
              <% editLog.forEach(e => { %>
                <div style="padding:8px;border-bottom:1px solid #e2e8f0;display:flex;justify-content:space-between;align-items:start;gap:8px;">
                  <div>
                    <strong style="color:var(--medium-blue);"><%= e.edited_by %></strong>
                    <span style="color:var(--dark-grey);"> — <%= e.edit_type %></span>
                    <% if (e.changes_detail) { %><div style="color:#4a5568;margin-top:2px;"><%= e.changes_detail %></div><% } %>
                  </div>
                  <div style="color:var(--dark-grey);white-space:nowrap;"><%= new Date(e.edited_at).toLocaleString('en-ZA') %></div>
                </div>
              <% }) %>
            </div>
          <% } %>
        </div>
      </div>
    </div>
  </div>
</div>
<script src="/js/app.js"></script>
</body>
</html>
