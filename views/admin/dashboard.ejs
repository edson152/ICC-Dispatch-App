<%- include('../partials/head') %>
<div class="app-layout">
  <%- include('../partials/sidebar') %>
  <div class="main-content">
    <%- include('../partials/topbar') %>
    <div class="page-body">

      <div class="stat-grid">
        <div class="stat-card"><div class="stat-icon blue">📦</div><div><div class="stat-label">Total Dispatches</div><div class="stat-value"><%= stats.total %></div></div></div>
        <div class="stat-card"><div class="stat-icon orange">⏳</div><div><div class="stat-label">Pending Capture</div><div class="stat-value"><%= stats.pending %></div></div></div>
        <div class="stat-card"><div class="stat-icon blue">🚚</div><div><div class="stat-label">Out for Delivery</div><div class="stat-value"><%= stats.dispatched %></div></div></div>
        <div class="stat-card"><div class="stat-icon green">✅</div><div><div class="stat-label">Delivered</div><div class="stat-value"><%= stats.delivered %></div></div></div>
        <div class="stat-card"><div class="stat-icon purple">🧾</div><div><div class="stat-label">Receipts Captured</div><div class="stat-value"><%= receiptCount %></div></div></div>
        <div class="stat-card"><div class="stat-icon light">💰</div><div><div class="stat-label">Total Value (Excl)</div><div class="stat-value" style="font-size:15px;">R <%= parseFloat(stats.total_value||0).toLocaleString('en-ZA',{minimumFractionDigits:2,maximumFractionDigits:2}) %></div></div></div>
      </div>

      <div style="display:grid;grid-template-columns:1fr 1fr;gap:20px;margin-bottom:20px;">
        <!-- Delivery Method Chart -->
        <div class="card">
          <div class="card-header">
            <span class="card-title">🚚 By Delivery Method</span>
            <div style="display:flex;gap:6px;">
              <% byDelivery.forEach(r => { %>
                <a href="/admin/delivery-detail/<%= encodeURIComponent(r.delivery_method) %>" class="btn btn-outline btn-sm" style="font-size:10px;padding:3px 8px;"><%= r.delivery_method %></a>
              <% }) %>
            </div>
          </div>
          <div class="card-body">
            <canvas id="deliveryChart" height="180"></canvas>
          </div>
        </div>
        <!-- Top Invoicers -->
        <div class="card">
          <div class="card-header"><span class="card-title">👤 Top Invoicers</span></div>
          <div class="card-body" style="padding:0;">
            <table style="width:100%;">
              <thead><tr style="background:var(--soft-grey);">
                <th style="padding:8px 14px;font-size:11px;font-weight:700;color:var(--dark-grey);text-transform:uppercase;">Employee</th>
                <th style="padding:8px 14px;font-size:11px;font-weight:700;color:var(--dark-grey);text-transform:uppercase;">Invoices</th>
                <th style="padding:8px 14px;font-size:11px;font-weight:700;color:var(--dark-grey);text-transform:uppercase;">Value</th>
              </tr></thead>
              <tbody>
                <% byEmployee.forEach(r => { %>
                  <tr style="border-bottom:1px solid var(--mid-grey);">
                    <td style="padding:9px 14px;font-size:13px;"><strong><%= r.invoiced_by||'Unknown' %></strong></td>
                    <td style="padding:9px 14px;"><span class="badge badge-info"><%= r.cnt %></span></td>
                    <td style="padding:9px 14px;font-size:12px;">R <%= parseFloat(r.total).toLocaleString('en-ZA',{minimumFractionDigits:2}) %></td>
                  </tr>
                <% }) %>
              </tbody>
            </table>
          </div>
        </div>
      </div>

      <!-- Recent PENDING -->
      <div class="card" style="margin-bottom:20px;">
        <div class="card-header">
          <span class="card-title">⏳ Recent Pending Dispatches</span>
          <a href="/admin/dispatches" class="btn btn-outline btn-sm">View All</a>
        </div>
        <div class="table-wrapper">
          <table>
            <thead><tr><th>Invoice #</th><th>Date</th><th>Customer</th><th>Invoiced By</th><th>Delivery</th><th>Transport</th><th>Captured By</th><th>Status</th></tr></thead>
            <tbody>
              <% recentPending.forEach(d => { %>
                <% const done = d.transport_company && d.transport_company.trim()!==''; %>
                <tr>
                  <td><strong style="color:var(--deep-blue)">#<%= d.inv_number %></strong></td>
                  <td><%= d.inv_date ? new Date(d.inv_date).toLocaleDateString('en-ZA',{day:'2-digit',month:'short',year:'numeric'}) : '—' %></td>
                  <td class="truncate" style="max-width:140px;" title="<%= d.acc_name %>"><%= d.acc_name %></td>
                  <td><%= d.invoiced_by||'—' %></td>
                  <td><span class="badge badge-info"><%= d.delivery_method %></span></td>
                  <td class="small"><%= d.transport_company||d.truck_name||'—' %></td>
                  <td><%= d.captured_by||'—' %></td>
                  <td><span class="badge <%=done?'badge-success':'badge-warning'%>"><%=done?'🚚 Out':'⏳ Pending'%></span></td>
                </tr>
              <% }) %>
            </tbody>
          </table>
        </div>
      </div>

      <!-- Recent COMPLETED -->
      <div class="card">
        <div class="card-header">
          <span class="card-title" style="color:var(--success);">✅ Recent Completed Deliveries</span>
          <a href="/admin/receipts" class="btn btn-outline btn-sm">See More</a>
        </div>
        <div class="table-wrapper">
          <table>
            <thead><tr><th>Invoice #</th><th>Date</th><th>Customer</th><th>Delivery</th><th>Transport</th><th>Captured By</th><th>Dispatched At</th></tr></thead>
            <tbody>
              <% completed.forEach(d => { %>
                <tr style="background:rgba(56,161,105,0.04);">
                  <td><strong style="color:var(--success)">#<%= d.inv_number %></strong></td>
                  <td><%= d.inv_date ? new Date(d.inv_date).toLocaleDateString('en-ZA',{day:'2-digit',month:'short',year:'numeric'}) : '—' %></td>
                  <td class="truncate" style="max-width:140px;"><%= d.acc_name %></td>
                  <td><span class="badge badge-info"><%= d.delivery_method %></span></td>
                  <td class="small"><%= d.transport_company||d.truck_name||'—' %></td>
                  <td><strong><%= d.captured_by||'—' %></strong></td>
                  <td class="small nowrap"><%= d.dispatched_at ? new Date(d.dispatched_at).toLocaleString('en-ZA') : '—' %></td>
                </tr>
              <% }) %>
              <% if (completed.length===0) { %>
                <tr><td colspan="7" style="text-align:center;padding:24px;color:var(--dark-grey);">No completed deliveries yet.</td></tr>
              <% } %>
            </tbody>
          </table>
        </div>
      </div>

    </div>
  </div>
</div>

<script src="https://cdnjs.cloudflare.com/ajax/libs/Chart.js/4.4.0/chart.umd.min.js"></script>
<script>
const deliveryData = <%- JSON.stringify(byDelivery) %>;
new Chart(document.getElementById('deliveryChart'), {
  type: 'doughnut',
  data: {
    labels: deliveryData.map(d => d.delivery_method),
    datasets: [{
      data: deliveryData.map(d => parseInt(d.cnt)),
      backgroundColor: ['#1A4A9C','#4A90D9','#63B3ED','#38A169','#D69E2E'],
      borderWidth: 2, borderColor: '#fff'
    }]
  },
  options: {
    responsive: true,
    plugins: {
      legend: { position: 'bottom', labels: { font: { family: 'Poppins', size: 12 } } }
    }
  }
});
</script>
<script src="/js/app.js"></script>
</body></html>
