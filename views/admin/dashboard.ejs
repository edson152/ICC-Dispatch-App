<%- include('../partials/head') %>
<div class="app-layout">
  <%- include('../partials/sidebar') %>
  <div class="main-content">
    <%- include('../partials/topbar') %>
    <div class="page-body">

      <!-- Stats -->
      <div class="stat-grid">
        <div class="stat-card">
          <div class="stat-icon blue">📦</div>
          <div>
            <div class="stat-label">Total Dispatches</div>
            <div class="stat-value"><%= stats.total %></div>
          </div>
        </div>
        <div class="stat-card">
          <div class="stat-icon green">✅</div>
          <div>
            <div class="stat-label">Transport Captured</div>
            <div class="stat-value"><%= stats.complete %></div>
          </div>
        </div>
        <div class="stat-card">
          <div class="stat-icon orange">⏳</div>
          <div>
            <div class="stat-label">Pending Details</div>
            <div class="stat-value"><%= stats.pending %></div>
          </div>
        </div>
        <div class="stat-card">
          <div class="stat-icon light">💰</div>
          <div>
            <div class="stat-label">Total Value (Excl)</div>
            <div class="stat-value">R <%= parseFloat(stats.total_value || 0).toLocaleString('en-ZA', {minimumFractionDigits:2,maximumFractionDigits:2}) %></div>
          </div>
        </div>
        <div class="stat-card">
          <div class="stat-icon purple">⚖</div>
          <div>
            <div class="stat-label">Total Weight</div>
            <div class="stat-value"><%= parseFloat(stats.total_weight || 0).toFixed(1) %> kg</div>
          </div>
        </div>
      </div>

      <div style="display:grid;grid-template-columns:1fr 1fr;gap:20px;margin-bottom:20px;">

        <!-- By Employee -->
        <div class="card">
          <div class="card-header"><span class="card-title">👤 Top Invoicers</span></div>
          <div class="table-wrapper">
            <table>
              <thead>
                <tr><th>Employee</th><th>Invoices</th><th>Value (Excl)</th></tr>
              </thead>
              <tbody>
                <% byEmployee.forEach(r => { %>
                  <tr>
                    <td><strong><%= r.invoiced_by || 'Unknown' %></strong></td>
                    <td><span class="badge badge-info"><%= r.cnt %></span></td>
                    <td>R <%= parseFloat(r.total).toLocaleString('en-ZA',{minimumFractionDigits:2}) %></td>
                  </tr>
                <% }) %>
              </tbody>
            </table>
          </div>
        </div>

        <!-- By Delivery -->
        <div class="card">
          <div class="card-header"><span class="card-title">🚚 Delivery Methods</span></div>
          <div class="table-wrapper">
            <table>
              <thead>
                <tr><th>Method</th><th>Count</th><th>Weight</th></tr>
              </thead>
              <tbody>
                <% byDelivery.forEach(r => { %>
                  <tr>
                    <td><span class="badge badge-info"><%= r.delivery_method %></span></td>
                    <td><%= r.cnt %></td>
                    <td><%= parseFloat(r.total_weight).toFixed(1) %> kg</td>
                  </tr>
                <% }) %>
              </tbody>
            </table>
          </div>
        </div>

      </div>

      <!-- Recent Dispatches -->
      <div class="card">
        <div class="card-header">
          <span class="card-title">📋 Recent Dispatch Activity</span>
          <a href="/admin/dispatches" class="btn btn-outline btn-sm">View All</a>
        </div>
        <div class="table-wrapper">
          <table>
            <thead>
              <tr>
                <th>Invoice #</th>
                <th>Date</th>
                <th>Customer</th>
                <th>Invoiced By</th>
                <th>Weight</th>
                <th>Delivery</th>
                <th>Transport Co.</th>
                <th>Driver</th>
                <th>Plate</th>
                <th>Captured By</th>
                <th>Status</th>
              </tr>
            </thead>
            <tbody>
              <% recent.forEach(d => { %>
                <% const done = d.transport_company && d.transport_company.trim() !== ''; %>
                <tr>
                  <td><strong style="color:var(--deep-blue)">#<%= d.inv_number %></strong></td>
                  <td><%= d.inv_date ? new Date(d.inv_date).toLocaleDateString('en-ZA',{day:'2-digit',month:'short',year:'numeric'}) : '—' %></td>
                  <td class="truncate" style="max-width:160px;" title="<%= d.acc_name %>"><%= d.acc_name %></td>
                  <td><%= d.invoiced_by || '—' %></td>
                  <td><%= d.weight ? d.weight + ' kg' : '—' %></td>
                  <td><span class="badge badge-info"><%= d.delivery_method %></span></td>
                  <td><%= d.transport_company || '<span class="text-muted">—</span>' %></td>
                  <td><%= d.driver_first_name ? d.driver_first_name + ' ' + d.driver_surname : '<span class="text-muted">—</span>' %></td>
                  <td><%= d.license_plate || '<span class="text-muted">—</span>' %></td>
                  <td><%= d.captured_by || '<span class="text-muted">—</span>' %></td>
                  <td><span class="badge <%= done ? 'badge-success' : 'badge-warning' %>"><%= done ? '✔ Done' : '⏳ Pending' %></span></td>
                </tr>
              <% }) %>
            </tbody>
          </table>
        </div>
      </div>

    </div>
  </div>
</div>
<script src="/js/app.js"></script>
</body>
</html>
