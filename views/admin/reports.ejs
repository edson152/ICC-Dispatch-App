<%- include('../partials/head') %>
<div class="app-layout">
  <%- include('../partials/sidebar') %>
  <div class="main-content">
    <%- include('../partials/topbar') %>
    <div class="page-body">
      <div style="margin-bottom:16px;"><a href="javascript:history.back()" class="btn btn-outline btn-sm">← Back</a></div>

      <div style="display:grid;grid-template-columns:1fr 1fr;gap:20px;margin-bottom:20px;">

        <!-- By Employee -->
        <div class="card">
          <div class="card-header"><span class="card-title">👤 Summary by Invoiced By</span></div>
          <div class="table-wrapper">
            <table>
              <thead>
                <tr><th>Employee</th><th>Invoices</th><th>Total (Excl)</th><th>Weight</th><th>Captured</th></tr>
              </thead>
              <tbody>
                <% byEmployee.forEach(r => { %>
                  <tr>
                    <td><strong><%= r.invoiced_by || 'Unknown' %></strong></td>
                    <td><span class="badge badge-info"><%= r.inv_count %></span></td>
                    <td>R <%= parseFloat(r.total_value).toLocaleString('en-ZA',{minimumFractionDigits:2}) %></td>
                    <td><%= parseFloat(r.total_weight).toFixed(1) %> kg</td>
                    <td><span class="badge <%= r.captured == r.inv_count ? 'badge-success' : 'badge-warning' %>"><%= r.captured %>/<%= r.inv_count %></span></td>
                  </tr>
                <% }) %>
              </tbody>
            </table>
          </div>
        </div>

        <!-- By Delivery Method -->
        <div class="card">
          <div class="card-header"><span class="card-title">🚚 Summary by Delivery Method</span></div>
          <div class="table-wrapper">
            <table>
              <thead>
                <tr><th>Method</th><th>Count</th><th>Total Weight</th><th>Total Value</th></tr>
              </thead>
              <tbody>
                <% byDelivery.forEach(r => { %>
                  <tr>
                    <td><span class="badge badge-info"><%= r.delivery_method %></span></td>
                    <td><%= r.cnt %></td>
                    <td><%= parseFloat(r.total_weight).toFixed(1) %> kg</td>
                    <td>R <%= parseFloat(r.total_value).toLocaleString('en-ZA',{minimumFractionDigits:2}) %></td>
                  </tr>
                <% }) %>
              </tbody>
            </table>
          </div>
        </div>

      </div>

      <!-- Monthly Trend -->
      <% if (monthly.length > 0) { %>
      <div class="card">
        <div class="card-header"><span class="card-title">📅 Monthly Activity (Last 6 Months)</span></div>
        <div class="card-body">
          <table>
            <thead>
              <tr><th>Month</th><th>Invoices</th><th>Total Value (Excl)</th><th>Bar</th></tr>
            </thead>
            <tbody>
              <% const maxVal = Math.max(...monthly.map(m => parseFloat(m.total_value))); %>
              <% monthly.forEach(m => { %>
                <% const pct = maxVal > 0 ? (parseFloat(m.total_value) / maxVal * 100) : 0; %>
                <tr>
                  <td><strong><%= m.month %></strong></td>
                  <td><span class="badge badge-info"><%= m.cnt %></span></td>
                  <td>R <%= parseFloat(m.total_value).toLocaleString('en-ZA',{minimumFractionDigits:2}) %></td>
                  <td style="width:200px;">
                    <div style="background:var(--mid-grey);border-radius:4px;height:10px;overflow:hidden;">
                      <div style="background:linear-gradient(90deg,var(--medium-blue),var(--light-blue));height:100%;width:<%= pct.toFixed(1) %>%;border-radius:4px;transition:width 0.5s;"></div>
                    </div>
                  </td>
                </tr>
              <% }) %>
            </tbody>
          </table>
        </div>
      </div>
      <% } %>

    </div>
  </div>
</div>
<script src="/js/app.js"></script>
</body>
</html>
