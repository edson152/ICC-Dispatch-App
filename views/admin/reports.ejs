<%- include('../partials/head') %>
<div class="app-layout">
  <%- include('../partials/sidebar') %>
  <div class="main-content">
    <%- include('../partials/topbar') %>
    <div class="page-body">
      <div style="margin-bottom:16px;"><a href="javascript:history.back()" class="btn btn-outline btn-sm">← Back</a></div>

      <div style="display:grid;grid-template-columns:1fr 1fr;gap:20px;margin-bottom:20px;">

        <!-- By Invoiced By -->
        <div class="card">
          <div class="card-header"><span class="card-title">👤 By Invoiced By</span></div>
          <div class="card-body" style="padding:0;">
            <table style="width:100%;">
              <thead><tr style="background:var(--soft-grey);">
                <th style="padding:8px 14px;font-size:11px;font-weight:700;color:var(--dark-grey);text-transform:uppercase;">Employee</th>
                <th style="padding:8px 14px;font-size:11px;font-weight:700;color:var(--dark-grey);text-transform:uppercase;">Orders</th>
                <th style="padding:8px 14px;font-size:11px;font-weight:700;color:var(--dark-grey);text-transform:uppercase;">Value</th>
                <th style="padding:8px 14px;font-size:11px;font-weight:700;color:var(--dark-grey);text-transform:uppercase;">Captured</th>
              </tr></thead>
              <tbody>
                <% byEmployee.forEach(r => { %>
                  <tr style="border-bottom:1px solid var(--mid-grey);">
                    <td style="padding:9px 14px;font-size:13px;font-weight:600;"><%= r.invoiced_by||'Unknown' %></td>
                    <td style="padding:9px 14px;"><span class="badge badge-info"><%= r.inv_count %></span></td>
                    <td style="padding:9px 14px;font-size:12px;">R <%= parseFloat(r.total_value).toLocaleString('en-ZA',{minimumFractionDigits:2}) %></td>
                    <td style="padding:9px 14px;"><span class="badge <%=r.captured==r.inv_count?'badge-success':'badge-warning'%>"><%= r.captured %>/<%= r.inv_count %></span></td>
                  </tr>
                <% }) %>
              </tbody>
            </table>
          </div>
        </div>

        <!-- By Delivery Method -->
        <div class="card">
          <div class="card-header"><span class="card-title">🚚 By Delivery Method</span></div>
          <div class="card-body" style="padding:0;">
            <table style="width:100%;">
              <thead><tr style="background:var(--soft-grey);">
                <th style="padding:8px 14px;font-size:11px;font-weight:700;color:var(--dark-grey);text-transform:uppercase;">Method</th>
                <th style="padding:8px 14px;font-size:11px;font-weight:700;color:var(--dark-grey);text-transform:uppercase;">Count</th>
                <th style="padding:8px 14px;font-size:11px;font-weight:700;color:var(--dark-grey);text-transform:uppercase;">Weight</th>
                <th style="padding:8px 14px;font-size:11px;font-weight:700;color:var(--dark-grey);text-transform:uppercase;">Value</th>
              </tr></thead>
              <tbody>
                <% byDelivery.forEach(r => { %>
                  <tr style="border-bottom:1px solid var(--mid-grey);">
                    <td style="padding:9px 14px;"><a href="/admin/delivery-detail/<%= encodeURIComponent(r.delivery_method) %>" style="color:var(--medium-blue);font-weight:600;font-size:13px;"><span class="badge badge-info"><%= r.delivery_method %></span></a></td>
                    <td style="padding:9px 14px;font-size:13px;"><%= r.cnt %></td>
                    <td style="padding:9px 14px;font-size:12px;"><%= parseFloat(r.total_weight).toFixed(1) %> kg</td>
                    <td style="padding:9px 14px;font-size:12px;">R <%= parseFloat(r.total_value).toLocaleString('en-ZA',{minimumFractionDigits:2}) %></td>
                  </tr>
                <% }) %>
              </tbody>
            </table>
          </div>
        </div>

        <!-- Packer Accountability -->
        <div class="card">
          <div class="card-header"><span class="card-title">📦 Packer Activity</span></div>
          <div class="card-body" style="padding:0;">
            <table style="width:100%;">
              <thead><tr style="background:var(--soft-grey);">
                <th style="padding:8px 14px;font-size:11px;font-weight:700;color:var(--dark-grey);text-transform:uppercase;">Packer</th>
                <th style="padding:8px 14px;font-size:11px;font-weight:700;color:var(--dark-grey);text-transform:uppercase;">Orders Packed</th>
              </tr></thead>
              <tbody>
                <% byPacker.forEach(r => { %>
                  <tr style="border-bottom:1px solid var(--mid-grey);">
                    <td style="padding:9px 14px;font-size:13px;font-weight:600;"><%= r.packer %></td>
                    <td style="padding:9px 14px;"><span class="badge badge-info"><%= r.cnt %></span></td>
                  </tr>
                <% }) %>
                <% if (!byPacker.length) { %><tr><td colspan="2" style="padding:16px;text-align:center;color:var(--dark-grey);font-size:12px;">No packer data</td></tr><% } %>
              </tbody>
            </table>
          </div>
        </div>

        <!-- Checker Accountability -->
        <div class="card">
          <div class="card-header"><span class="card-title">✔ Checker Activity</span></div>
          <div class="card-body" style="padding:0;">
            <table style="width:100%;">
              <thead><tr style="background:var(--soft-grey);">
                <th style="padding:8px 14px;font-size:11px;font-weight:700;color:var(--dark-grey);text-transform:uppercase;">Checker</th>
                <th style="padding:8px 14px;font-size:11px;font-weight:700;color:var(--dark-grey);text-transform:uppercase;">Orders Checked</th>
              </tr></thead>
              <tbody>
                <% byChecker.forEach(r => { %>
                  <tr style="border-bottom:1px solid var(--mid-grey);">
                    <td style="padding:9px 14px;font-size:13px;font-weight:600;"><%= r.checker %></td>
                    <td style="padding:9px 14px;"><span class="badge badge-success"><%= r.cnt %></span></td>
                  </tr>
                <% }) %>
                <% if (!byChecker.length) { %><tr><td colspan="2" style="padding:16px;text-align:center;color:var(--dark-grey);font-size:12px;">No checker data</td></tr><% } %>
              </tbody>
            </table>
          </div>
        </div>

      </div>

      <!-- Monthly Trend -->
      <% if (monthly.length) { %>
      <div class="card">
        <div class="card-header"><span class="card-title">📅 Monthly Trend (Last 6 Months)</span></div>
        <div class="card-body">
          <% const maxVal=Math.max(...monthly.map(m=>parseFloat(m.total_value)),1); %>
          <% monthly.forEach(m => { %>
            <% const pct=Math.round(parseFloat(m.total_value)/maxVal*100); %>
            <div style="margin-bottom:14px;">
              <div style="display:flex;justify-content:space-between;margin-bottom:5px;">
                <span style="font-size:13px;font-weight:600;"><%= m.month %></span>
                <span style="font-size:12px;color:var(--dark-grey);"><%= m.cnt %> orders · R <%= parseFloat(m.total_value).toLocaleString('en-ZA',{minimumFractionDigits:2}) %></span>
              </div>
              <div style="background:var(--mid-grey);border-radius:6px;height:10px;overflow:hidden;">
                <div style="background:linear-gradient(90deg,var(--deep-blue),var(--light-blue));height:100%;width:<%= pct %>%;border-radius:6px;"></div>
              </div>
            </div>
          <% }) %>
        </div>
      </div>
      <% } %>

    </div>
  </div>
</div>
<script src="/js/app.js"></script>
</body></html>
