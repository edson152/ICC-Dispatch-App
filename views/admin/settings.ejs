<%- include('../partials/head') %>
<div class="app-layout">
  <%- include('../partials/sidebar') %>
  <div class="main-content">
    <%- include('../partials/topbar') %>
    <div class="page-body">
      <div style="margin-bottom:16px;"><a href="javascript:history.back()" class="btn btn-outline btn-sm">← Back</a></div>
      <div class="card" style="max-width:700px;">
        <div class="card-header"><span class="card-title">⚙ System Settings</span></div>
        <div class="card-body">
          <form method="POST" action="/admin/settings">
            <div class="section-title">📷 Photo Requirements</div>
            <div style="display:flex;flex-direction:column;gap:14px;margin-bottom:28px;">
              <label class="toggle-row">
                <input type="checkbox" name="require_goods_photo" <%= settings.require_goods_photo==='true'?'checked':'' %>>
                <span class="toggle-label">Require goods/parcel photos before dispatch can be saved</span>
              </label>
              <label class="toggle-row">
                <input type="checkbox" name="require_driver_photo" <%= settings.require_driver_photo==='true'?'checked':'' %>>
                <span class="toggle-label">Require driver photo upload</span>
              </label>
              <label class="toggle-row">
                <input type="checkbox" name="require_license_photo" <%= settings.require_license_photo==='true'?'checked':'' %>>
                <span class="toggle-label">Require driver license photo</span>
              </label>
            </div>
            <div class="section-title">📱 SMS Notifications</div>
            <div style="background:rgba(74,144,217,0.07);border:1px solid rgba(74,144,217,0.2);border-radius:8px;padding:16px;margin-bottom:20px;">
              <p style="font-size:13px;color:var(--text-dark);margin:0 0 12px;">SMS uses <strong>BulkSMS.com</strong> — South Africa's leading bulk SMS provider. Set your API credentials in the <code>.env</code> file:</p>
              <code style="font-size:12px;background:var(--soft-grey);padding:8px 12px;border-radius:6px;display:block;">BULKSMS_USERNAME=your_username<br>BULKSMS_PASSWORD=your_password<br>BULKSMS_SENDER=ICCDispatch</code>
            </div>
            <label class="toggle-row" style="margin-bottom:20px;">
              <input type="checkbox" name="sms_enabled" <%= settings.sms_enabled==='true'?'checked':'' %>>
              <span class="toggle-label">Enable SMS notifications to customers on dispatch</span>
            </label>
            <button type="submit" class="btn btn-blue">💾 Save Settings</button>
          </form>
        </div>
      </div>
    </div>
  </div>
</div>
<script src="/js/app.js"></script>
</body></html>
