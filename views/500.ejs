<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8"><meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>500 — Server Error · ICC Dispatch</title>
  <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@400;600;700;800&display=swap" rel="stylesheet">
  <style>
    *{margin:0;padding:0;box-sizing:border-box;}
    body{font-family:'Poppins',sans-serif;background:#F4F6FA;min-height:100vh;display:flex;align-items:center;justify-content:center;padding:20px;}
    .card{background:white;border-radius:16px;padding:52px 40px;max-width:480px;width:100%;box-shadow:0 8px 32px rgba(0,0,0,0.08);text-align:center;}
    .icon{font-size:72px;margin-bottom:20px;}
    h1{font-size:28px;font-weight:800;color:#0D2B5E;margin-bottom:8px;}
    .code{font-size:72px;font-weight:800;color:#E53E3E;line-height:1;margin-bottom:16px;}
    p{color:#718096;font-size:14px;line-height:1.7;margin-bottom:24px;}
    .btn{display:inline-flex;align-items:center;gap:8px;padding:12px 24px;background:#0D2B5E;color:white;border-radius:10px;text-decoration:none;font-weight:700;font-size:14px;margin:4px;}
    .btn-outline{background:transparent;border:2px solid #0D2B5E;color:#0D2B5E;}
    <% if (process.env.NODE_ENV !== 'production') { %>
    .error-detail{background:#FFF5F5;border:1px solid #FEB2B2;border-radius:8px;padding:14px;margin-top:20px;text-align:left;font-size:12px;font-family:monospace;color:#C53030;word-break:break-all;}
    <% } %>
  </style>
</head>
<body>
  <div class="card">
    <div class="code">500</div>
    <div class="icon">⚙️</div>
    <h1>Something went wrong</h1>
    <p>The server encountered an error processing your request. Our team has been notified. Please try again or go back to the previous page.</p>
    <div>
      <a href="javascript:history.back()" class="btn btn-outline">← Go Back</a>
      <a href="/" class="btn">🏠 Home</a>
    </div>
    <% if (typeof error !== 'undefined' && error && process.env.NODE_ENV !== 'production') { %>
      <div class="error-detail"><strong>Dev info:</strong><br><%= error.message || error %></div>
    <% } %>
  </div>
</body></html>
