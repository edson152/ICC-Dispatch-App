<%- include('../partials/head') %>
<div class="app-layout">
  <%- include('../partials/sidebar') %>
  <div class="main-content">
    <%- include('../partials/topbar') %>
    <div class="page-body">
      <div style="margin-bottom:16px;"><a href="javascript:history.back()" class="btn btn-outline btn-sm">← Back</a></div>

      <!-- Quick lookup -->
      <div class="card" style="margin-bottom:14px;">
        <div class="card-body" style="padding:14px 20px;">
          <div style="display:flex;gap:10px;align-items:flex-end;flex-wrap:wrap;">
            <div>
              <label style="font-size:11px;font-weight:700;color:var(--deep-blue);text-transform:uppercase;letter-spacing:0.5px;display:block;margin-bottom:5px;">Quick Lookup by Invoice Number</label>
              <input type="text" id="invoiceLookup" class="form-control" placeholder="Type invoice number & press Enter" style="width:260px;" value="<%= dispatch.inv_number %>">
            </div>
            <button type="button" class="btn btn-blue btn-sm" onclick="lookupInvoice()">🔍 Go</button>
          </div>
        </div>
      </div>

      <div class="card">
        <div class="card-header">
          <span class="card-title">📝 Invoice #<%= dispatch.inv_number %> — <%= dispatch.acc_name %></span>
          <span class="badge <%=dispatch.dispatch_status==='delivered'?'badge-success':dispatch.dispatch_status==='dispatched'?'badge-info':'badge-warning'%>"><%= dispatch.dispatch_status||'pending' %></span>
        </div>
        <div class="card-body">

          <!-- READ-ONLY invoice info -->
          <div class="section-title">📄 Invoice Details <span style="font-size:10px;color:var(--dark-grey);font-weight:400;text-transform:none;">(read-only — from database)</span></div>
          <div class="detail-grid" style="margin-bottom:20px;">
            <div class="detail-field highlight"><label>Invoice #</label><span>#<%= dispatch.inv_number %></span></div>
            <div class="detail-field highlight"><label>Date</label><span><%= dispatch.inv_date?new Date(dispatch.inv_date).toLocaleDateString('en-ZA'):'—' %></span></div>
            <div class="detail-field highlight"><label>Order #</label><span><%= dispatch.order_num||'—' %></span></div>
            <div class="detail-field" style="grid-column:span 2;"><label>Customer</label><span><%= dispatch.acc_name||'—' %></span></div>
            <div class="detail-field" style="grid-column:span 3;"><label>Address</label><span><%= dispatch.address?(dispatch.address+(dispatch.city?', '+dispatch.city:'')):'—' %></span></div>
            <div class="detail-field"><label>Email</label><span><%= dispatch.email||'—' %></span></div>
            <div class="detail-field"><label>Phone</label><span><%= dispatch.phone||'—' %></span></div>
            <div class="detail-field"><label>Delivery Method</label><span><span class="badge badge-info"><%= dispatch.delivery_method %></span></span></div>
            <div class="detail-field"><label>Picker</label><span><%= dispatch.picker||'—' %></span></div>
            <div class="detail-field"><label>Packer</label><span><%= dispatch.packer||'—' %></span></div>
            <div class="detail-field"><label>Checker</label><span><%= dispatch.checker||'—' %></span></div>
            <div class="detail-field"><label>Bales</label><span style="font-weight:700;color:var(--medium-blue);"><%= dispatch.bales||0 %></span></div>
            <div class="detail-field"><label>Boxes</label><span style="font-weight:700;color:var(--medium-blue);"><%= dispatch.boxes||0 %></span></div>
            <div class="detail-field"><label>Grey Bags</label><span><%= dispatch.grey_bags||0 %></span></div>
            <div class="detail-field"><label>Total Packages</label><span><%= dispatch.total_packages||'—' %></span></div>
            <div class="detail-field"><label>Invoice Value</label><span style="color:var(--medium-blue);font-weight:700;">R <%= dispatch.inv_tot_excl?parseFloat(dispatch.inv_tot_excl).toLocaleString('en-ZA',{minimumFractionDigits:2}):'0.00' %></span></div>
          </div>

          <hr class="section-divider">

          <form method="POST" action="/dispatch/capture/<%= dispatch.inv_number %>" enctype="multipart/form-data" id="transportForm">

            <!-- Transport mode -->
            <div class="section-title">🚛 Transport Details</div>
            <div class="form-row" style="margin-bottom:20px;">
              <label>Mode of Transport</label>
              <div style="display:flex;gap:10px;flex-wrap:wrap;">
                <label class="transport-option">
                  <input type="radio" name="transport_mode" value="icc" onchange="switchMode('icc')" <%=(dispatch.icc_truck_id)?'checked':''%>>
                  <span>🚛 ICC Truck</span>
                </label>
                <label class="transport-option">
                  <input type="radio" name="transport_mode" value="courier" onchange="switchMode('courier')" <%=(!dispatch.icc_truck_id&&dispatch.delivery_method==='Courier')?'checked':''%>>
                  <span>📦 Courier / 3rd Party</span>
                </label>
                <label class="transport-option">
                  <input type="radio" name="transport_mode" value="collection" onchange="switchMode('collection')" <%=(dispatch.delivery_method==='Collection')?'checked':''%>>
                  <span>🏪 Collection</span>
                </label>
              </div>
            </div>

            <!-- ICC Truck panel -->
            <div id="panel-icc" class="transport-panel" style="display:none;">
              <div class="form-row">
                <label>Select ICC Truck</label>
                <select class="form-control" name="icc_truck_id" id="truckSelect" onchange="loadTruck(this.value)" style="max-width:420px;">
                  <option value="">— Choose a truck —</option>
                  <% trucks.forEach(t => { %>
                    <option value="<%= t.id %>" <%=dispatch.icc_truck_id==t.id?'selected':''%>>
                      🚛 <%= t.truck_name %> — <%= t.license_plate %><%= t.driver_name?' ('+t.driver_name+(t.driver_surname?' '+t.driver_surname:'')+')':'' %>
                    </option>
                  <% }) %>
                </select>
              </div>
              <input type="hidden" name="transport_company" value="ICC Truck">
            </div>

            <!-- Courier panel -->
            <div id="panel-courier" class="transport-panel" style="display:none;">
              <div class="form-row">
                <label>Courier / Transport Company</label>
                <input class="form-control" name="transport_company" id="f_transport" list="courierList"
                  value="<%=dispatch.delivery_method==='Courier'?dispatch.transport_company||'':''%>"
                  placeholder="e.g. DHL, Fastway, RAM, Skynet" style="max-width:420px;" autocomplete="off">
                <datalist id="courierList">
                  <% (prevCouriers||[]).forEach(c => { %><option value="<%= c %>"><% }) %>
                  <option value="DHL"><option value="Fastway"><option value="RAM Couriers">
                  <option value="Skynet"><option value="Courier Guy"><option value="Aramex"><option value="Dawn Wing">
                </datalist>
                <div style="font-size:11px;color:var(--dark-grey);margin-top:4px;">Previously used couriers will be suggested as you type</div>
              </div>
            </div>

            <!-- Collection panel -->
            <div id="panel-collection" class="transport-panel" style="display:none;">
              <input type="hidden" name="transport_company" value="Collection">
              <div style="background:rgba(74,144,217,0.07);border:1px solid rgba(74,144,217,0.2);border-radius:8px;padding:14px;font-size:13px;color:var(--medium-blue);">
                🏪 Customer collects — add details of the person collecting below if needed.
              </div>
            </div>

            <!-- Shared driver fields -->
            <div id="driverFields" style="margin-top:20px;">
              <div class="form-grid">
                <div class="form-row">
                  <label>Driver First Name</label>
                  <input class="form-control" name="driver_first_name" id="f_first" value="<%= dispatch.driver_first_name||'' %>" list="driverFirstList" autocomplete="off">
                  <datalist id="driverFirstList"><% (prevDrivers||[]).forEach(d=>{%><option value="<%= d.first %>"><% }) %></datalist>
                </div>
                <div class="form-row">
                  <label>Driver Surname</label>
                  <input class="form-control" name="driver_surname" id="f_sur" value="<%= dispatch.driver_surname||'' %>" list="driverSurList" autocomplete="off">
                  <datalist id="driverSurList"><% (prevDrivers||[]).forEach(d=>{%><option value="<%= d.surname %>"><% }) %></datalist>
                </div>
                <div class="form-row">
                  <label>Driver Phone</label>
                  <input class="form-control" name="driver_phone" id="f_phone" value="<%= dispatch.driver_phone||'' %>" placeholder="+27 xx xxx xxxx">
                </div>
                <div class="form-row">
                  <label>License Plate</label>
                  <input class="form-control" name="license_plate" id="f_plate" value="<%= dispatch.license_plate||'' %>"
                    placeholder="e.g. ABC 123 GP" oninput="validatePlate(this)" style="text-transform:uppercase;" list="plateList" autocomplete="off">
                  <datalist id="plateList"><% (prevPlates||[]).forEach(p=>{%><option value="<%= p %>"><% }) %></datalist>
                  <div id="plateError" style="color:var(--danger);font-size:12px;margin-top:4px;display:none;">⚠ Invalid plate format. Check province/format (e.g. ABC 123 GP)</div>
                </div>
                <div class="form-row">
                  <label>Tracking / Waybill Number</label>
                  <input class="form-control" name="tracking_number" value="<%= dispatch.tracking_number||'' %>" placeholder="Tracking or waybill number">
                </div>
              </div>
              <div class="form-row">
                <label>Notes</label>
                <textarea class="form-control" name="notes" rows="2" placeholder="Any additional notes..."><%= dispatch.notes||'' %></textarea>
              </div>
            </div>

            <hr class="section-divider">

            <!-- Notification channel -->
            <div class="section-title">📱 Notify Customer & Driver</div>
            <div class="form-row" style="margin-bottom:20px;">
              <label>Send notification via</label>
              <div style="display:flex;gap:10px;flex-wrap:wrap;">
                <label class="transport-option">
                  <input type="radio" name="notify_channel" value="sms" <%=settings.notification_channel==='sms'?'checked':''%>>
                  <span>💬 SMS</span>
                </label>
                <label class="transport-option">
                  <input type="radio" name="notify_channel" value="whatsapp" <%=settings.notification_channel==='whatsapp'?'checked':''%>>
                  <span>📱 WhatsApp</span>
                </label>
                <label class="transport-option">
                  <input type="radio" name="notify_channel" value="both" <%=settings.notification_channel==='both'?'checked':''%>>
                  <span>📲 Both</span>
                </label>
                <label class="transport-option">
                  <input type="radio" name="notify_channel" value="none" <%=settings.notification_channel==='none'?'checked':''%>>
                  <span>🔕 None</span>
                </label>
              </div>
              <div style="font-size:11px;color:var(--dark-grey);margin-top:6px;">Customer receives delivery details · Driver receives delivery address & packages · Reply 1=Received, 2=Not received</div>
            </div>

            <hr class="section-divider">

            <!-- Photos -->
            <div class="section-title">📷 Photos <span style="font-size:10px;color:var(--dark-grey);font-weight:400;text-transform:none;"><%= settings.require_goods_photo==='true'?'(Required)':'(Optional)' %></span></div>
            <div class="form-grid">
              <div class="form-row">
                <label>Goods / Parcel Photos</label>
                <input type="file" name="goods_photos" class="form-control" accept="image/*,video/*" multiple>
                <div style="font-size:11px;color:var(--dark-grey);margin-top:4px;">Up to 5 photos or videos</div>
              </div>
              <div class="form-row">
                <label>Driver's License Photo</label>
                <input type="file" name="license_photo" class="form-control" accept="image/*">
              </div>
              <div class="form-row">
                <label>Driver Photo</label>
                <input type="file" name="driver_photo_upload" class="form-control" accept="image/*">
              </div>
            </div>

            <% if (media && media.length) { %>
              <div style="margin:10px 0 16px;">
                <div style="font-size:11px;font-weight:700;color:var(--dark-grey);text-transform:uppercase;letter-spacing:0.5px;margin-bottom:8px;">Previously Uploaded</div>
                <div style="display:flex;flex-wrap:wrap;gap:8px;">
                  <% media.forEach(m => { %>
                    <% const sub=m.media_type==='goods'?'goods':m.media_type==='license'?'licenses':'drivers'; %>
                    <div style="border:1px solid var(--mid-grey);border-radius:8px;padding:6px;text-align:center;width:88px;">
                      <% if(/image/i.test(m.mime_type)){%>
                        <a href="/uploads/<%= sub %>/<%= m.file_name %>" target="_blank">
                          <img src="/uploads/<%= sub %>/<%= m.file_name %>" style="width:72px;height:54px;object-fit:cover;border-radius:4px;display:block;margin-bottom:4px;">
                        </a>
                      <%}else{%>
                        <div style="width:72px;height:54px;background:var(--soft-grey);border-radius:4px;display:flex;align-items:center;justify-content:center;font-size:20px;margin-bottom:4px;">📄</div>
                      <%}%>
                      <span class="badge badge-info" style="font-size:9px;"><%= m.media_type %></span>
                    </div>
                  <% }) %>
                </div>
              </div>
            <% } %>

            <% if (dispatch.captured_by) { %>
              <div style="background:var(--soft-grey);border-radius:8px;padding:10px 14px;margin-bottom:16px;font-size:12px;color:var(--dark-grey);">
                Previously captured by <strong><%= dispatch.captured_by %></strong><% if(dispatch.captured_at){%> on <%= new Date(dispatch.captured_at).toLocaleString('en-ZA') %><% } %>
              </div>
            <% } %>

            <div style="display:flex;gap:12px;">
              <button type="submit" class="btn btn-blue">💾 Save & Dispatch</button>
              <a href="javascript:history.back()" class="btn btn-outline">Cancel</a>
            </div>
          </form>
        </div>
      </div>
    </div>
  </div>
</div>

<style>
.transport-option{display:inline-flex;align-items:center;gap:8px;padding:10px 18px;border:2px solid var(--mid-grey);border-radius:10px;cursor:pointer;font-size:13px;font-weight:600;transition:all 0.15s;background:var(--white);}
.transport-option:has(input:checked){border-color:var(--medium-blue);background:rgba(26,74,156,0.07);color:var(--deep-blue);}
.transport-option input{display:none;}
</style>

<script>
const trucks=<%- JSON.stringify(trucks.map(t=>({id:t.id,first:t.driver_name,sur:t.driver_surname,phone:t.driver_phone,plate:t.license_plate}))) %>;

function switchMode(mode){
  ['icc','courier','collection'].forEach(m=>{document.getElementById('panel-'+m).style.display=mode===m?'block':'none';});
  document.getElementById('driverFields').style.display=mode==='collection'?'none':'block';
}

function loadTruck(id){
  if(!id)return;
  const t=trucks.find(t=>t.id==id);
  if(!t)return;
  document.getElementById('f_first').value=t.first||'';
  document.getElementById('f_sur').value=t.sur||'';
  document.getElementById('f_phone').value=t.phone||'';
  document.getElementById('f_plate').value=t.plate||'';
}

const PLATES=[/^[A-Z]{3}\s?\d{3}\s?[A-Z]{2}$/,/^[A-Z]{2}\s?\d{2}\s?[A-Z]{2}$/,/^ICC[-\s]?\d{1,4}$/i,/^[A-Z0-9]{2,10}$/];
function validatePlate(el){
  el.value=el.value.toUpperCase();
  const v=el.value.trim();
  const ok=!v||PLATES.some(r=>r.test(v));
  document.getElementById('plateError').style.display=ok?'none':'block';
  el.style.borderColor=ok?'':'var(--danger)';
}

function lookupInvoice(){
  const n=document.getElementById('invoiceLookup').value.trim();
  if(n) window.location.href='/dispatch/capture/'+n;
}
document.getElementById('invoiceLookup').addEventListener('keydown',e=>{if(e.key==='Enter'){e.preventDefault();lookupInvoice();}});

// Init mode on load
const currentMode='<%=dispatch.icc_truck_id?"icc":dispatch.delivery_method==="Collection"?"collection":"courier"%>';
switchMode(currentMode);
const radio=document.querySelector(`input[name="transport_mode"][value="${currentMode}"]`);
if(radio)radio.checked=true;
</script>
<script src="/js/app.js"></script>
</body></html>
