<%- include('../partials/head') %>
<div class="app-layout">
  <%- include('../partials/sidebar') %>
  <div class="main-content">
    <%- include('../partials/topbar') %>
    <div class="page-body">
      <div style="margin-bottom:16px;">
        <a href="/dispatch" class="btn btn-outline btn-sm">← Back to Dispatch Orders</a>
      </div>

      <div class="card">
        <div class="card-header">
          <span class="card-title">📝 Capture / Edit — Invoice #<%= dispatch.inv_number %></span>
          <span style="font-size:12px;color:var(--dark-grey);">Editing as: <strong style="color:var(--medium-blue);"><%= user.name %></strong></span>
        </div>
        <div class="card-body">

          <!-- Capturer banner -->
          <div style="background:linear-gradient(135deg,#EBF8FF,#E6FFFA);border:1px solid #90CDF4;border-radius:8px;padding:12px 16px;margin-bottom:24px;font-size:13px;color:#2b6cb0;">
            ✏️ <strong>Editing by:</strong> <strong style="color:var(--deep-blue);"><%= user.name %></strong> — all changes will be logged automatically.
          </div>

          <!-- Invoice Info -->
          <div class="section-title">📄 Invoice Information</div>
          <div class="detail-grid">
            <div class="detail-field highlight"><label>Invoice #</label><span>#<%= dispatch.inv_number %></span></div>
            <div class="detail-field highlight"><label>Date</label><span><%= dispatch.inv_date ? new Date(dispatch.inv_date).toLocaleDateString('en-ZA',{day:'2-digit',month:'short',year:'numeric'}) : '—' %></span></div>
            <div class="detail-field"><label>Order #</label><span><%= dispatch.order_num || '—' %></span></div>
            <div class="detail-field"><label>Account No</label><span><%= dispatch.acc_no || '—' %></span></div>
            <div class="detail-field" style="grid-column:span 2;"><label>Customer Name</label><span><%= dispatch.acc_name || '—' %></span></div>
            <div class="detail-field"><label>Email</label><span><%= dispatch.email || '—' %></span></div>
            <div class="detail-field"><label>Delivery Method</label><span><span class="badge badge-info"><%= dispatch.delivery_method %></span></span></div>
            <div class="detail-field"><label>Packages</label><span><%= dispatch.total_packages || '—' %></span></div>
            <div class="detail-field"><label>Invoice Total (Excl)</label><span style="color:var(--medium-blue);font-weight:700;">R <%= dispatch.inv_tot_excl ? parseFloat(dispatch.inv_tot_excl).toLocaleString('en-ZA',{minimumFractionDigits:2}) : '0.00' %></span></div>
          </div>

          <hr class="section-divider">

          <!-- Transport + Media Upload Form -->
          <div class="section-title">🚛 Transport Details &amp; Goods Media Upload</div>
          <form method="POST" action="/dispatch/capture/<%= dispatch.inv_number %>" enctype="multipart/form-data">
            <div class="form-grid">
              <div class="form-row">
                <label>Transport / Courier Company</label>
                <input class="form-control" name="transport_company" value="<%= dispatch.transport_company || '' %>" placeholder="e.g. DHL, Fastway, ICC Truck">
              </div>
              <div class="form-row">
                <label>Driver First Name</label>
                <input class="form-control" name="driver_first_name" value="<%= dispatch.driver_first_name || '' %>" placeholder="Driver's first name">
              </div>
              <div class="form-row">
                <label>Driver Surname</label>
                <input class="form-control" name="driver_surname" value="<%= dispatch.driver_surname || '' %>" placeholder="Driver's surname">
              </div>
              <div class="form-row">
                <label>License Plate</label>
                <input class="form-control" name="license_plate" value="<%= dispatch.license_plate || '' %>" placeholder="e.g. ABC 123 GP" style="text-transform:uppercase;">
              </div>
              <div class="form-row">
                <label>Tracking / Waybill Number</label>
                <input class="form-control" name="tracking_number" value="<%= dispatch.tracking_number || '' %>" placeholder="Enter tracking or waybill number">
              </div>
              <div class="form-row">
                <label>Notes</label>
                <input class="form-control" name="notes" value="<%= dispatch.notes || '' %>" placeholder="Any additional notes">
              </div>
            </div>

            <!-- Media Upload Section -->
            <div style="margin:20px 0;background:var(--soft-grey);border-radius:10px;padding:20px;">
              <div style="font-weight:700;color:var(--deep-blue);margin-bottom:8px;font-size:14px;">📸📹 Upload Goods Photos / Videos / Receipt Images</div>
              <p style="font-size:12px;color:var(--dark-grey);margin:0 0 12px;">Photos/videos will be sent to the customer and visible to admin. Max 50MB per file. Accepted: JPG, PNG, MP4, MOV, PDF.</p>
              <input type="file" name="goods_media" multiple accept="image/*,video/*,.pdf" class="form-control" style="background:white;">
              <p style="font-size:11px;color:var(--dark-grey);margin:6px 0 0;">You can select multiple files at once. 📧 Photos will be automatically emailed to the customer and admin.</p>
            </div>

            <% if (dispatch.captured_by) { %>
              <div style="background:var(--soft-grey);border-radius:8px;padding:12px 16px;margin-bottom:20px;font-size:13px;color:var(--dark-grey);">
                Previously captured by <strong><%= dispatch.captured_by %></strong><% if (dispatch.captured_at) { %> on <%= new Date(dispatch.captured_at).toLocaleString('en-ZA') %><% } %>
              </div>
            <% } %>

            <div style="display:flex;gap:12px;">
              <button type="submit" class="btn btn-blue">💾 Save &amp; Upload — Notify Admin &amp; Customer</button>
              <a href="/dispatch" class="btn btn-outline">Cancel</a>
            </div>
          </form>

          <!-- Existing Media Gallery -->
          <% if (media && media.length > 0) { %>
            <hr class="section-divider">
            <div class="section-title">🖼️ Uploaded Goods Media (<%= media.length %> files)</div>
            <div style="display:grid;grid-template-columns:repeat(auto-fill,minmax(160px,1fr));gap:12px;margin-top:12px;">
              <% media.forEach(m => { %>
                <div style="background:white;border:1px solid #e2e8f0;border-radius:8px;overflow:hidden;text-align:center;">
                  <% if (m.mime_type && m.mime_type.startsWith('image/')) { %>
                    <a href="/uploads/goods/<%= m.file_name %>" target="_blank">
                      <img src="/uploads/goods/<%= m.file_name %>" style="width:100%;height:120px;object-fit:cover;" alt="<%= m.original_name %>">
                    </a>
                  <% } else if (m.mime_type && m.mime_type.startsWith('video/')) { %>
                    <video style="width:100%;height:120px;object-fit:cover;" controls>
                      <source src="/uploads/goods/<%= m.file_name %>" type="<%= m.mime_type %>">
                    </video>
                  <% } else { %>
                    <a href="/uploads/goods/<%= m.file_name %>" target="_blank" style="display:block;padding:30px;font-size:32px;">📄</a>
                  <% } %>
                  <div style="padding:8px;font-size:11px;color:var(--dark-grey);">
                    <div style="font-weight:600;word-break:break-all;" title="<%= m.original_name %>"><%= m.original_name.length > 20 ? m.original_name.substring(0,18)+'...' : m.original_name %></div>
                    <div>By: <%= m.uploaded_by %></div>
                    <form method="POST" action="/dispatch/media/delete/<%= m.id %>" onsubmit="return confirm('Remove this file?');" style="margin-top:4px;">
                      <button type="submit" style="background:none;border:none;color:#e53e3e;cursor:pointer;font-size:11px;text-decoration:underline;">🗑 Remove</button>
                    </form>
                  </div>
                </div>
              <% }) %>
            </div>
          <% } %>

          <!-- Edit Log -->
          <% if (editLog && editLog.length > 0) { %>
            <hr class="section-divider">
            <div class="section-title">📋 Edit History (Audit Trail)</div>
            <div style="background:var(--soft-grey);border-radius:8px;padding:12px;font-size:12px;">
              <% editLog.forEach(e => { %>
                <div style="padding:8px;border-bottom:1px solid #e2e8f0;display:flex;justify-content:space-between;align-items:start;gap:8px;">
                  <div>
                    <strong style="color:var(--medium-blue);"><%= e.edited_by %></strong>
                    <span style="color:var(--dark-grey);"> — <%= e.edit_type %></span>
                    <% if (e.changes_detail) { %><div style="color:#4a5568;margin-top:2px;"><%= e.changes_detail %></div><% } %>
                  </div>
                  <div style="color:var(--dark-grey);white-space:nowrap;"><%= new Date(e.edited_at).toLocaleString('en-ZA') %></div>
                </div>
              <% }) %>
            </div>
          <% } %>

        </div>
      </div>
    </div>
  </div>
</div>
<script src="/js/app.js"></script>
</body>
</html>
