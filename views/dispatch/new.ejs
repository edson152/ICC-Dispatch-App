<%- include('../partials/head') %>
<div class="app-layout">
  <%- include('../partials/sidebar') %>
  <div class="main-content">
    <%- include('../partials/topbar') %>
    <div class="page-body">
      <div style="margin-bottom:16px;">
        <a href="/dispatch" class="btn btn-outline btn-sm">← Back to Dispatch Orders</a>
      </div>
      <div class="card">
        <div class="card-header">
          <span class="card-title">➕ Add New Invoice</span>
          <span style="font-size:12px;color:var(--dark-grey);">Captured by: <strong style="color:var(--medium-blue);"><%= user.name %></strong></span>
        </div>
        <div class="card-body">
          <% if (error && error.length) { %><div class="alert alert-error"><%= error[0] %></div><% } %>
          <form method="POST" action="/dispatch/new">
            <!-- Capturer auto-fill notice -->
            <div style="background:linear-gradient(135deg,#EBF8FF,#E6FFFA);border:1px solid #90CDF4;border-radius:8px;padding:12px 16px;margin-bottom:24px;font-size:13px;color:#2b6cb0;">
              📋 <strong>Capturer:</strong> <strong style="color:var(--deep-blue);"><%= user.name %></strong> — automatically logged as the person creating this invoice.
            </div>

            <div class="section-title">📄 Invoice Details</div>
            <div class="form-grid">
              <div class="form-row">
                <label class="required">Invoice Number</label>
                <input class="form-control" name="inv_number" type="number" placeholder="e.g. 778000" required>
              </div>
              <div class="form-row">
                <label class="required">Invoice Date</label>
                <input class="form-control" type="date" name="inv_date" value="<%= new Date().toISOString().slice(0,10) %>" required>
              </div>
              <div class="form-row">
                <label>Order Number</label>
                <input class="form-control" name="order_num" placeholder="e.g. 630500">
              </div>
              <div class="form-row">
                <label class="required">Account No</label>
                <input class="form-control" name="acc_no" placeholder="e.g. AMO001" required>
              </div>
              <div class="form-row" style="grid-column:span 2;">
                <label class="required">Customer / Account Name</label>
                <input class="form-control" name="acc_name" placeholder="Full customer name" required>
              </div>
              <div class="form-row">
                <label>Customer Email</label>
                <input class="form-control" type="email" name="email" placeholder="customer@example.com">
              </div>
              <div class="form-row">
                <label>Customer Order No</label>
                <input class="form-control" name="cust_ord_no" placeholder="Customer's own PO number">
              </div>
            </div>

            <hr class="section-divider">
            <div class="section-title">👥 Staff Details</div>
            <div class="form-grid">
              <div class="form-row">
                <label>Internal Rep</label>
                <input class="form-control" name="internal_rep" placeholder="Internal sales rep">
              </div>
              <div class="form-row">
                <label>External Rep</label>
                <input class="form-control" name="ext_rep" placeholder="External rep">
              </div>
              <div class="form-row">
                <label>Picker</label>
                <input class="form-control" name="picker" placeholder="Picker name">
              </div>
              <div class="form-row">
                <label>Packer 1</label>
                <input class="form-control" name="packer" placeholder="Packer name">
              </div>
              <div class="form-row">
                <label>Packer 2</label>
                <input class="form-control" name="packer2" placeholder="Second packer (if any)">
              </div>
              <div class="form-row">
                <label>Checker</label>
                <input class="form-control" name="checker" placeholder="Checker name">
              </div>
            </div>

            <hr class="section-divider">
            <div class="section-title">📦 Packaging & Delivery</div>
            <div class="form-grid">
              <div class="form-row">
                <label>Weight (kg)</label>
                <input class="form-control" type="number" step="0.1" name="weight" placeholder="e.g. 18.5">
              </div>
              <div class="form-row">
                <label>Boxes</label>
                <input class="form-control" type="number" name="boxes" value="0" min="0">
              </div>
              <div class="form-row">
                <label>Bales</label>
                <input class="form-control" type="number" name="bales" value="0" min="0">
              </div>
              <div class="form-row">
                <label>Grey Bags</label>
                <input class="form-control" type="number" name="grey_bags" value="0" min="0">
              </div>
              <div class="form-row">
                <label class="required">Delivery Method</label>
                <select class="form-control" name="delivery_method" required>
                  <option value="">Select delivery method</option>
                  <option value="ICC Truck">ICC Truck</option>
                  <option value="Courier">Courier</option>
                  <option value="Collection">Collection</option>
                  <option value="Post">Post</option>
                </select>
              </div>
              <div class="form-row">
                <label>Invoice Total (Excl VAT)</label>
                <input class="form-control" type="number" step="0.01" name="inv_tot_excl" placeholder="e.g. 6657.80">
              </div>
              <div class="form-row" style="grid-column:span 2;">
                <label>Notes</label>
                <input class="form-control" name="notes" placeholder="Any additional notes">
              </div>
            </div>

            <div style="display:flex;gap:12px;margin-top:8px;">
              <button type="submit" class="btn btn-blue">➕ Create Invoice &amp; Upload Goods Photos</button>
              <a href="/dispatch" class="btn btn-outline">Cancel</a>
            </div>
          </form>
        </div>
      </div>
    </div>
  </div>
</div>
<script src="/js/app.js"></script>
</body>
</html>
