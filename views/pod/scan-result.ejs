<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8"><meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= title %></title>
  <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@400;600;700;800&display=swap" rel="stylesheet">
  <style>
    *{margin:0;padding:0;box-sizing:border-box;}
    body{font-family:'Poppins',sans-serif;background:#F4F6FA;min-height:100vh;display:flex;align-items:center;justify-content:center;padding:20px;}
    .card{background:white;border-radius:16px;padding:40px 32px;max-width:400px;width:100%;box-shadow:0 8px 32px rgba(0,0,0,0.1);text-align:center;}
    .icon{font-size:64px;margin-bottom:16px;}
    h2{font-size:22px;font-weight:800;margin-bottom:8px;}
    p{color:#718096;font-size:14px;margin-bottom:6px;}
    .detail{background:#F4F6FA;border-radius:10px;padding:14px;margin:20px 0;font-size:13px;color:#0D2B5E;font-weight:600;}
  </style>
</head>
<body>
<div class="card">
  <% if (error) { %>
    <div class="icon">❌</div>
    <h2 style="color:#E53E3E;">Error</h2>
    <p><%= error %></p>
  <% } else if (alreadyDone) { %>
    <div class="icon">⚠️</div>
    <h2 style="color:#D69E2E;">Already Scanned</h2>
    <p>This POD was already confirmed.</p>
    <% if (result) { %>
    <div class="detail">Invoice #<%= result.inv_number %> — <%= result.acc_name %><br>
    Scanned on <%= result.scanned_at ? new Date(result.scanned_at).toLocaleString('en-ZA') : '—' %></div>
    <% } %>
  <% } else { %>
    <div class="icon">✅</div>
    <h2 style="color:#38A169;">POD Confirmed!</h2>
    <p>Invoice has been marked as delivered and archived to the completed logs.</p>
    <% if (result && result.inv_number) { %>
    <div class="detail">Invoice #<%= result.inv_number %><br><%= result.acc_name %></div>
    <% } %>
    <p style="font-size:12px;color:#A0AEC0;margin-top:12px;">Industrial Clothing Company · Dispatch System</p>
  <% } %>
</div>
</body></html>
