<%- include('../partials/head') %>
<div class="app-layout">
  <%- include('../partials/sidebar') %>
  <div class="main-content">
    <%- include('../partials/topbar') %>
    <div class="page-body">
      <div style="margin-bottom:16px;display:flex;gap:10px;align-items:center;">
        <a href="javascript:history.back()" class="btn btn-outline btn-sm">← Back</a>
        <a href="/receipts/manual" class="btn btn-blue btn-sm">➕ New Receipt</a>
      </div>

      <div class="card">
        <div class="card-header">
          <span class="card-title">🧾 Delivery Receipts</span>
          <span style="font-size:12px;color:var(--dark-grey);"><%= receipts.length %> receipt(s)</span>
        </div>
        <div class="table-wrapper">
          <table>
            <thead>
              <tr>
                <th>Receipt #</th><th>Invoice #</th><th>Customer</th><th>Receipt Date</th>
                <th>Received By</th><th>Condition</th><th>Tracking #</th><th>Captured By</th><th>Action</th>
              </tr>
            </thead>
            <tbody>
              <% receipts.forEach(r => { %>
                <tr>
                  <td><strong style="color:var(--deep-blue)">#<%= r.id %></strong></td>
                  <td><strong>#<%= r.inv_number %></strong></td>
                  <td class="truncate" style="max-width:160px;" title="<%= r.acc_name %>"><%= r.acc_name %></td>
                  <td class="nowrap"><%= r.receipt_date ? new Date(r.receipt_date).toLocaleDateString('en-ZA',{day:'2-digit',month:'short',year:'numeric'}) : '—' %></td>
                  <td><%= r.received_by || '—' %></td>
                  <td><span class="badge <%= r.condition === 'Good' ? 'badge-success' : r.condition === 'Damaged' ? 'badge-danger' : 'badge-warning' %>"><%= r.condition %></span></td>
                  <td class="small"><%= r.tracking_number || '—' %></td>
                  <td><strong><%= r.captured_by %></strong></td>
                  <td><a href="/receipts/view/<%= r.id %>" class="btn btn-outline btn-sm">👁 View</a></td>
                </tr>
              <% }) %>
              <% if (receipts.length === 0) { %>
                <tr><td colspan="9" style="text-align:center;padding:40px;color:var(--dark-grey);">No receipts captured yet.</td></tr>
              <% } %>
            </tbody>
          </table>
        </div>
      </div>

    </div>
  </div>
</div>
<script src="/js/app.js"></script>
</body>
</html>
